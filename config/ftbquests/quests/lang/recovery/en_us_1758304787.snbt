{
	"chapters/industrial_foregoing.snbt": {
		quest.3E6706BC4C318A40.title: {
			new: "Sewer"
			old: "Other Machines"
		}
		quest.0EC2053B191C55C6.quest_desc: {
			new: ["Extracts latex from logs, runs faster when given power.\\n\\nCheck JEI for acceptable logs and Latex amounts. The best log to use is Acacia."]
			old: [
				"Extracts latex from logs."
				""
				"Check JEI for acceptable logs and latex amounts."
			]
		}
		quest.55820773BDD5319D.quest_desc: {
			new: ["&bIndustrial Foregoing&r (IF for short) is a tech mod that adds many machines with various different uses.\\n\\nTo get started, craft a &aPity Machine Frame&r."]
			old: ["Welcome to &aIndustrial Foregoing&f!"]
		}
	}
	"chapters/ars_nouveau.snbt": {
		quest.6F3602F5600A6221.title: {
			new: "&4Tier 3 Glyphs"
			old: "Tier 3 Glyphs"
		}
		quest.6B511C8B572E8940.quest_desc: {
			new: ["In the bottom left of your screen, you'll see a bar. This bar is your mana pool! \\n\\nThere are several ways to increase your mana pool, or increase the efficiency of your spells as you progress through the mod. Upgrading your spellbook can also increase your mana!"]
			old: [
				"En la parte inferior izquierda de tu pantalla, verás una barra. ¡Esta barra es tu reserva de maná!"
				""
				"Hay varias formas de aumentar tu reserva de maná o aumentar la eficiencia de tus hechizos a medida que avanzas en el mod. ¡Actualizar tu libro de hechizos también puede aumentar tu maná!"
			]
		}
		quest.3D862A3D3F83CA26.quest_desc: {
			new: [
				"The &9Enchanting Apparatus&r is used to craft various items within the mod. It requires Source to work.\\n\\nIt is also a multiblock structure that utilizes Arcane Pedestals to craft.\\n\\nStart by placing an Arcane Core in the ground, then place the Enchanting Apparatus on top of it. Surround the Apparatus with Arcane Pedestals.\\n"
				"{image:atm:textures/questpics/ars/enchanting_app.png width:200 height:175 align:1}"
			]
			old: [
				"El &9Aparato encantador&r se utiliza para crear varios elementos dentro del mod. Requiere Source para funcionar."
				""
				"También es una estructura multibloque que utiliza pedestales arcanos para crear"
				"."
				""
				"Comience colocando un Núcleo Arcano en el suelo, luego coloque el Aparato Encantador encima de él. Rodea el aparato con pedestales arcanos."
				""
			]
		}
		quest.41A0BE357C8A74E1.quest_desc: {
			new: ["The &9Alchemical Sourcelink&r produces Source from adjacent potion jars. \\n\\nThe amount of source varies per potion and complexity."]
			old: [
				"El &9Alchemical Sourcelink&r produce Fuente a partir de frascos de pociones adyacentes."
				""
				"La cantidad de fuente varía según la poción y la complejidad."
			]
		}
		quest.17D7D34F519F7E5F.quest_desc: {
			new: ["To create the final tier of your Spellbook, you'll need to have killed the &6Wilden Chimera&r. \\n\\nThis is a Ritual that you'll need to complete using a &9Ritual Brazier&r."]
			old: [
				"Para crear el nivel final de tu libro de hechizos, deberás haber matado a &6Wilden Chimera&r."
				""
				"Este es un ritual que deberás completar usando un &9Ritual Brazier&r."
			]
		}
		quest.58EC47584C773B82.quest_desc: {
			new: ["Using our Enchanting Apparatus structure, we'll want to craft our first seed, the &5Magebloom Seed&r. \\n\\nThis will be used to create us some magical clothing!"]
			old: [
				"Usando nuestra estructura de Aparato Encantador, querremos crear nuestra primera semilla, la &5Magebloom Seed&r."
				""
				"¡Esto se usará para crearnos ropa mágica!"
			]
		}
		quest.14DB8A515CA50932.quest_desc: {
			new: ["The &9Enchanter's Sword&r allows you to attach a Touch Spell to the sword. \\n\\nAll spells on the Sword gain 1 additional Amplify augment to the last effect on the spell. \\n\\nTo apply a spell to the sword, use a Scribe's Table. Create the spell without using a form."]
			old: [
				"La &9Enchanter's Sword&r te permite adjuntar un hechizo de toque a la espada. "
				""
				"Todos los hechizos de la Espada obtienen 1 aumento de Amplificación adicional hasta el último efecto del hechizo."
				""
				"Para aplicar un hechizo a la espada, utiliza una mesa de escriba. Crea el hechizo sin usar un formulario."
			]
		}
		quest.111649D7E16D869F.quest_desc: {
			new: ["The &9Caster's Wand&r only accepts a single spell, and is inscribed using the Scribe's Table. \\n\\nWand spells always start with Projectile > Accelerate, and MUST be inscribed with a spell that does not have another method (like touch, self, etc). \\n\\nThis allows you to cast spells beyond the 10 spell cap. If you want to use Break, just inscribe the wand with Break by itself."]
			old: [
				"La &9Caster's Wand&r solo acepta un único hechizo y se inscribe usando la Tabla del Escriba."
				""
				"Los hechizos de varita siempre comienzan con Proyectil > Acelerar, y DEBEN estar inscritos con un hechizo que no tenga otro método (como tocar, uno mismo, etc.)."
				""
				"Esto te permite lanzar hechizos más allá del límite de 10 hechizos. Si desea utilizar Break, simplemente inscriba la varita con Break por sí misma."
			]
		}
		quest.3142A40E1EAEBAA3.quest_desc: {
			new: ["The &6Dowsing Rod&r gives you Magic Find and Scrying when used. \\n\\nThis allows you to see nearby magic creatures as well as helping you find amethyst!"]
			old: [
				"La &6Dowsing Rod&r te brinda búsqueda mágica y exploración cuando se usa."
				""
				"¡Esto te permite ver criaturas mágicas cercanas y te ayuda a encontrar amatista!"
			]
		}
		quest.5C3FF43CF16BCF30.title: {
			new: "&5Sourcestone"
			old: "Sourcestones"
		}
		quest.2D0CF18C8B2ABB7D.quest_subtitle: {
			new: "Creates Source using the growth of Plants"
			old: "Crea Fuente utilizando el crecimiento de las Plantas."
		}
		quest.6E0E13806F388D7E.quest_desc: {
			new: ["Welcome to &aArs Nouveau&f! \\n\\nArs Nouveau is a magic mod that allows you to create custom spells with the different Glyphs made within the mod!"]
			old: [
				"Bienvenido A &aArs Nouveau&f!"
				""
				"Ars Nouveau ¡Es un mod mágico que te permite crear hechizos personalizados con los diferentes glifos creados dentro del mod!"
			]
		}
		task.03EB390E79866058.title: {
			new: "Sourcestones"
			old: "Sourcestone"
		}
		quest.51162B9185A45BB1.quest_desc: {
			new: ["This bow can be inscribed with a spell using a Scribe's Table. \\n\\nAt the cost of mana, arrows will become Spell Arrows and will apply the spell on their target. \\n\\nIf you have no arrows, a spell arrow that deals 0 damage will be cast. If there is not enough mana, regular arrows will be fired instead. \\n\\nThe &9Enchanter's Bow&r can also use special Augment Arrows that empower the inscribed spell."]
			old: [
				"A este arco se le puede inscribir un hechizo usando una Mesa de Escriba."
				""
				"A costa de maná, las flechas se convertirán en flechas de hechizo y aplicarán el hechizo a su objetivo."
				""
				"Si no tienes flechas, se lanzará una flecha de hechizo que causa 0 daño. Si no hay suficiente maná, se dispararán flechas normales."
				""
				"El &9Enchanter's Bow&r también puede usar flechas de aumento especiales que potencian el hechizo inscrito."
			]
		}
		quest.632BC46928CC9A8C.quest_desc: {
			new: ["The &9Enchanter's Mirror&r will apply a self spell when used. \\n\\nSpells cast with this mirror are discounted and gain additional bonus duration. \\n\\nTo apply a spell, use a Scribe's table. Create a spell without using a form."]
			old: [
				"El &9Espejo del Encantador&r aplicará un auto hechizo cuando se use."
				""
				"Los hechizos lanzados con este espejo tienen descuento y obtienen una duración adicional adicional."
				""
				"Para aplicar un hechizo, utiliza la mesa de un escriba. Crea un hechizo sin usar un formulario."
			]
		}
		quest.0D330FAD6C993DBC.quest_desc: {
			new: ["This is the next upgrade to your Spellbook! \\n\\nThis will increase your overall mana and mana regen, as well as allowing you to create and use Tier 2 Glyphs."]
			old: [
				"¡Esta es la próxima actualización de tu Libro de Hechizos!"
				""
				"Esto aumentará tu maná general y tu regeneración de maná, además de desbloquear la capacidad de crear y usar glifos de nivel 2."
			]
		}
		quest.441C0659ED28D935.title: {
			new: "&aTier 1 Glyphs"
			old: "Tier 1 Glyphs"
		}
		quest.63DD7F5A4441ACE7.quest_desc: {
			new: ["Tier 2 Glyphs require 5 levels of experience to be made. \\n\\nThey also require a &9Mage's Spell Book&r to create."]
			old: [
				"Los glifos de nivel 2 requieren 5 niveles de experiencia para crearse."
				""
				"También requieren un &9Libro de hechizos de mago&r para crearlos."
			]
		}
		quest.6A1C0B17B22CE50F.title: {
			new: "&cThe Amulets"
			old: "Los amuletos"
		}
		quest.3D4D88B8BE881351.quest_subtitle: {
			new: "Upgrading Spells"
			old: "Mejora de hechizos"
		}
		quest.3D862A3D3F83CA26.title: {
			new: "&9Enchanting Apparatus"
			old: "Enchanting Apparatus"
		}
		quest.58EC47584C773B82.title: {
			new: "&5Magebloom Seed"
			old: "Semilla de flor mágica"
		}
		quest.19D02325579F2AA8.quest_desc: {
			new: ["The Volcanic Sourcelink generates Source by consuming burnable items. Archwood logs will generate bonus Source. \\n\\nAs it burns items, it will convert nearby stone into lava. \\n\\nThis also generates Lava Lilys."]
			old: [
				"El Volcanic Sourcelink genera Fuente al consumir elementos quemables. Los troncos de Archwood generarán una fuente adicional."
				""
				"A medida que quema objetos, convertirá la piedra cercana en lava."
				""
				"Esto también genera Lava Lilys."
			]
		}
		quest.457DE8C154641437.quest_desc: {
			new: ["The &9Ritual Brazier&r is used to cast rituals. It can also be used for decoration. If you want to light the Brazier, use a Light spell on it. \\n\\nTo perform rituals, you'll need Arcane Pedestals as well. As there are so many rituals to cast, make sure to check out each of them using the &6Worn Notebook&r! \\n\\nThis can be done by holding Ctrl on the Ritual Table while the book is in your inventory."]
			old: [
				"El Ritual Brazier se utiliza para realizar rituales. También se puede utilizar para decoración. Si quieres encender el Brasero, usa un hechizo de Luz sobre él."
				""
				"Para realizar rituales, también necesitarás pedestales arcanos. Como hay tantos rituales que realizar, ¡asegúrate de revisar cada uno de ellos usando el &6Cuaderno desgastado&r!"
				""
				"Esto se puede hacer manteniendo presionada la tecla Ctrl en la Mesa de rituales mientras el libro está en su inventario."
			]
		}
		quest.5C3FF43CF16BCF30.quest_desc: {
			new: ["With Source Gems, you can get started crafting the various machines by creating &5Sourcestones&r."]
			old: ["Con Source Gems, puedes comenzar a crear las distintas máquinas creando &5Sourcestones&r."]
		}
		quest.1D86B2E553503E53.title: {
			new: "&6Summoning Help!"
			old: "¡Invocando ayuda!"
		}
		quest.33682F4B44950123.quest_desc: {
			new: ["To gain further knowledge of spells, we'll need a specific type of magical wood!"]
			old: [
				"Para profundizar en el conocimiento de los hechizos, ¡necesitaremos un tipo específico de madera mágica!"
				""
				"Los árboles Archwood se pueden encontrar en el supramundo."
			]
		}
		quest.41A0BE357C8A74E1.quest_subtitle: {
			new: "Power through Potions"
			old: "Poder a través de pociones"
		}
		quest.227DBA8836021B0B.quest_desc: {
			new: ["In Ars Nouveau, the power system for machines is called &9Source&r. \\n\\nTo start collecting some Source, we'll need a Source Jar. \\n\\nSource can also be moved with buckets, or by breaking and picking up Source Jars."]
			old: [
				"En Ars Nouveau, el sistema de energía para las máquinas se llama &9Source&r."
				""
				"Para comenzar a recolectar algo de Fuente, necesitaremos un Source Jar."
				""
				"La fuente también se puede mover con cubos o rompiendo y recogiendo los tarros de fuente."
			]
		}
		quest.3D4D88B8BE881351.quest_desc: {
			new: ["If you want to cast better spells, you'll need a &6Scribe's Table&r to unlock new glyphs for your spellbook. \\n\\nThere are 3 tiers of glyphs to unlock, and each one requires some experience and items. \\n\\nThe Scribe's Table is also used to attach spells to Spell Parchments. To do this, place a Spell Parchment on the table, select the spell in your Spellbook, then sneak right-click the book on the table. \\n\\nTo create a Glyph, right-click on the Scribe's Table with your spellbook. Search for the glyph you want to make, then click Select at the bottom. Right-click the table with the items required, and the glyph will be created. Use the glyph to learn it. \\n\\nNote: The table can pull items from nearby inventories."]
			old: [
				"Si quieres lanzar mejores hechizos, necesitarás una &6Tabla de escribas&r para desbloquear nuevos glifos para tu libro de hechizos."
				""
				"Hay 3 niveles de glifos para desbloquear y cada uno requiere algo de experiencia y elementos."
				""
				"La Mesa del Escriba también se utiliza para adjuntar hechizos a los Pergaminos de Hechizos. Para hacer esto, coloca un pergamino de hechizos en la mesa, selecciona el hechizo en tu libro de hechizos y luego haz clic derecho en el libro sobre la mesa."
				""
				"Para crear un glifo, haz clic derecho en la mesa del escriba con tu libro de hechizos. Busque el glifo que desea crear y luego haga clic en Seleccionar en la parte inferior. Haga clic derecho en la tabla con los elementos requeridos y el"
				""
				"Nota: La mesa puede extraer elementos de inventarios cercanos."
			]
		}
		quest.04D9F6587EF8D9B7.quest_desc: {
			new: ["The &9Potion Jar&r stores up to 100 potions. You can remove them by using an empty bottle or a potion flask on the jar. \\n\\nWixies will use these jars during Potion Autocrafting."]
			old: [
				"El &9Potion Jar&r almacena hasta 100 pociones. Puedes eliminarlos usando una botella vacía o un frasco de poción en el frasco."
				""
				"Los Wixies usarán estos frascos durante la elaboración automática de pociones."
			]
		}
		quest.6A1C0B17B22CE50F.quest_desc: {
			new: ["The &9Amulet of Mana Boost&r gives a boost to max mana. \\n\\nThe &6Amulet of Mana Regen&r gives a boost to your mana regen."]
			old: [
				"El &9Amulet of Mana Boost&r aumenta el maná máximo."
				""
				"El &6Amulet of Mana Regen&r aumenta tu regeneración de maná."
			]
		}
		quest.40BC67BDEE15D1DE.title: {
			new: "&dSource Gems"
			old: "&5Gemas de origen"
		}
		quest.1D86B2E553503E53.quest_desc: {
			new: ["The &6Dominion Wand&r is used for controlling the creatures you might encounter in the world! Each being responds differently to the wand, so make sure to read up in the Worn Notebook!"]
			old: ["¡La Varita Dominion se usa para controlar las criaturas que puedes encontrar en el mundo! Cada ser responde de manera diferente a la varita, ¡así que asegúrate de leer en el Cuaderno Usado!"]
		}
		quest.77145113CD5B26FB.quest_desc: {
			new: ["Source Berries produce more Source than other sources. \\n\\nThis will also convert grass or dirt into Mycelium in a 3x3 area around it. It will also grow mushrooms around it if the space is empty."]
			old: [
				"Las bayas de origen producen más origen que otras fuentes."
				""
				"Esto también convertirá la hierba o la tierra en micelio en un área de 3x3 a su alrededor. También crecerán hongos a su alrededor si el espacio está vacío."
			]
		}
		quest.151648179684B088.quest_desc: {
			new: ["Runic Chalk is used to draw permanent Runes on that ground. These runes will cast spells on entities that walk over them. \\n\\nTo attach a spell to a rune, inscribe a &eSpell Parchment&r using a Scribe's Table.\\n\\nNote: The Rune will need Source to operate."]
			old: [
				"Runic Chalk se usa para dibujar Runas permanentes en ese terreno. Estas runas lanzarán hechizos sobre las entidades que caminen sobre ellas."
				""
				"Para adjuntar un hechizo a una runa, inscriba un &eSpell Pergamino&r usando una Tabla de Escriba."
				""
				"Nota: La Runa necesitará la Fuente para funcionar."
			]
		}
		quest.542C6D76B579886C.quest_desc: {
			new: ["Using those seeds, we'll want to craft our first fiber, the &5Magebloom Fiber&r. \\n\\nThis will be used to create us some magical accessories!"]
			old: [
				"Cuando tus semillas de Magebloom... florezcan, puedes usar Magebloom para crear fibras."
				""
				"¡Estos se utilizan para crear varios elementos, incluido tu primer conjunto de armadura mágica!"
			]
		}
		quest.295C77EEC89000FC.quest_subtitle: {
			new: "Generates Source from Mob Deaths and Animal Breeding"
			old: "Genera fuente a partir de muertes de mafias y cría de animales"
		}
		quest.3142A40E1EAEBAA3.quest_subtitle: {
			new: "Magic Finder"
			old: "Buscador mágico"
		}
		quest.04D9F6587EF8D9B7.quest_subtitle: {
			new: "Storing Potions"
			old: "Almacenamiento de pociones"
		}
		quest.40BC67BDEE15D1DE.quest_desc: {
			new: ["To create Source Gems, we'll need to put either Lapis or Amethyst Shards into the Imbuement Chamber. Over time, these will convert to Source Gems!"]
			old: ["Para crear Source Gems, necesitaremos colocar Lapislázuli o Amethyst Shards en la Cámara de Imbuement. ¡Con el tiempo, estas se convertirán en Source Gems!"]
		}
		quest.77145113CD5B26FB.quest_subtitle: {
			new: "Generates Source from Nearby Food"
			old: "Genera fuente a partir de alimentos cercanos"
		}
		quest.0E2AD156E5EF263A.quest_desc: {
			new: ["Used to inscribe spells on with the Scribe's Table."]
			old: ["Se utiliza para inscribir hechizos en la Mesa del Escriba."]
		}
		quest.3182E8AF755104E4.quest_desc: {
			new: ["When blocking damage, the &9Enchanter's Shield&r will give the user Mana Regen and Spell Damage for a short amount of time. \\n\\nAdditionally, the shield will repair itself over time using the wearer's mana."]
			old: [
				"Al bloquear el daño, el &9Enchanter's Shield&r le dará al usuario regeneración de maná y daño de hechizos por un corto período de tiempo."
				""
				"Además, el escudo se reparará solo con el tiempo utilizando el maná del usuario."
			]
		}
		quest.18A2FBE2D4133FA2.quest_desc: {
			new: ["Arcane Pedestals are needed for the Ritual Brazier and crafting items with an Enchanting Apparatus. \\n\\nGo ahead and make yourself 8 of them!"]
			old: [
				"Se necesitan pedestales arcanos para el brasero ritual y para fabricar objetos con un aparato encantador."
				""
				"¡Anímate y hazte 8 de ellos!"
			]
		}
		quest.64D0E66CB4FBEC82.quest_subtitle: {
			new: "Our First Spellbook"
			old: "Nuestro primer libro de hechizos"
		}
		quest.6DAA82B5F94AF9F8.quest_desc: {
			new: ["The &9Jar of Light&r summons a floating light source that follows you. \\n\\nThe &6Jar of Voiding&r destroys items you pick up in exchange for mana. This can be filtered. \\n\\nTo add or remove an item to be destroyed by the jar, use the jar with the item in your off hand, or use an item on the Scribe's Table with the jar placed on it. \\n\\nThe jar must be on your hotbar to function."]
			old: [
				"El &9Jar of Light&r invoca una fuente de luz flotante que te sigue."
				""
				"El &6Jar of Voiding&r destruye los objetos que recoges a cambio de maná. Esto se puede filtrar."
				""
				"Para agregar o quitar un objeto que será destruido por el frasco, use el frasco con el objeto en su mano libre, o use un objeto en la Mesa del Escriba con el frasco colocado sobre él."
				""
				"El frasco debe estar en su barra de acceso rápido para funcionar."
			]
		}
		quest.227DBA8836021B0B.quest_subtitle: {
			new: "Storing Source"
			old: "Fuente de almacenamiento"
		}
		quest.5766C8B9E850C186.quest_subtitle: {
			new: "Creating Source Gems"
			old: "Creando gemas fuente"
		}
		quest.5766C8B9E850C186.quest_desc: {
			new: [
				"To create one of the main crafting items in Ars, the &9Source Gem&r, we'll need to make an &6Imbuement Chamber&r. \\n\\nThe Imbuement Chamber requires Source to imbue items. It produces a small amount of Source by itself, but can also use Source Jars as a power source. \\n\\nSeveral recipes also require Arcane Pedestals to be placed around it as well.\\n"
				"{image:atm:textures/questpics/ars/imbuement.png width:200 height:150 align:1}"
			]
			old: [
				"Para crear uno de los principales elementos de artesanía en Ars, la &9Source Gem&r, necesitaremos hacer una &6Imbuement Chamber&r."
				""
				"La Cámara de Imbución requiere que la Fuente imbuya los elementos. Produce una pequeña cantidad de Source por sí solo, pero también puede usar Source Jars como fuente de energía."
				""
				"Varias recetas también requieren que se coloquen pedestales arcanos a su alrededor."
				""
				""
			]
		}
		quest.0A1ABE9CF7740AAA.quest_desc: {
			new: ["The Rings of Discount provides a small bonus to max mana and mana regen. It also reduces the total cost to cast a spell."]
			old: ["El Anillo de descuento proporciona una pequeña bonificación al maná máximo y a la regeneración de maná. También reduce el coste total de lanzar un hechizo."]
		}
		task.1B916AE67F84E6D7.title: {
			new: "Creating Your First Spell"
			old: "Creando tu primer hechizo"
		}
		quest.088FCB5267CB7A89.quest_desc: {
			new: ["This belt will give random positive potion effects for a short duration. These will vary in strength."]
			old: ["Este cinturón dará efectos de poción positivos aleatorios durante un breve período. Estos variarán en fuerza. "]
		}
		quest.2D0CF18C8B2ABB7D.quest_desc: {
			new: ["Placing this near growing plants or saplings will provide Source. Archwood trees provide more Source! \\n\\nNote: Bonemealing does not produce Source."]
			old: [
				"Colocar esto cerca de plantas en crecimiento o árboles jóvenes proporcionará Fuente. ¡Los árboles Archwood proporcionan más Fuente!"
				""
				"Nota: La harina de huesos no produce Fuente."
			]
		}
		quest.3FD702B5AB006402.quest_desc: {
			new: ["Have you ever wanted to just hover everywhere you go? \\n\\nThis belt allows you to levitate. To activate, just sneak while in the air, either while falling or from jumping."]
			old: [
				"¿Alguna vez has querido simplemente flotar dondequiera que vayas?"
				""
				"Este cinturón te permite levitar. Para activarlo, simplemente sigilosamente mientras estás en el aire, ya sea mientras caes o saltas."
			]
		}
		quest.5C3FF43CF16BCF30.quest_subtitle: {
			new: "Formerly \"Arcane Stones\""
			old: "Anteriormente conocidas como \"Piedras Arcanas\""
		}
		quest.63DD7F5A4441ACE7.title: {
			new: "&eTier 2 Glyphs"
			old: "Tier 2 Glyphs"
		}
		quest.64D0E66CB4FBEC82.quest_desc: {
			new: ["To get started, you'll need to craft yourself a &6Novice Spellbook&r! \\n\\nThis is where you create and store your spells. \\n\\nHitting the &9C&r key will open up the 'Create a Spell' page. On the left, there are several tabs, but the main 3 are: Spell Creation, Color Picker, and Familiars. \\n\\nThis spellbook will only allow you to create and use Tier 1 Glyphs. To create better spells, you'll need to upgrade your Spellbook!"]
			old: [
				"Para comenzar, necesitarás crear un &6libro de hechizos para principiantes&r."
				""
				"Aquí es donde creas y almacenas tus hechizos."
				""
				"Al presionar la tecla &9C&r se abrirá la página \"Crear un hechizo\". A la izquierda, hay varias pestañas, pero las 3 principales son: Creación de hechizos, Selector de color y Familiares."
				""
				"Este libro de hechizos solo te permitirá crear y usar glifos de nivel 1. ¡Para crear mejores hechizos, necesitarás actualizar tu Libro de hechizos!"
			]
		}
		quest.6F3602F5600A6221.quest_desc: {
			new: ["Tier 3 Glyphs require 10 levels of experience to be made. \\n\\nThey also require an &6Archmage Spell Book&r."]
			old: [
				"Los glifos de nivel 3 requieren 10 niveles de experiencia para crearse."
				""
				"También requieren un &6libro de hechizos del archimago&r."
			]
		}
		quest.58EC47584C773B82.quest_subtitle: {
			new: "Growing Magic"
			old: "Magia creciente"
		}
		quest.5CFBA24B3E0CDEDD.quest_desc: {
			new: [
				"While holding your Spellbook, you can press C to open up the spell creation page. \\n\\nEach spell must have a form. You start off with 3 basic forms: Projectile, Self-cast, and Touch. \\n\\nFor the Effect, this determines what happens when you cast the spell. You can have up to 9 effects per spell. \\n\\nFor starters, you have Harm and Break. \\n\\nSelect one Form and one Effect, name your spell, and click create!"
				""
				"{image:atm:textures/questpics/ars/spellbook.png width:200 height:150 align:1}"
			]
			old: [
				"Mientras sostienes tu libro de hechizos, puedes presionar C para abrir la página de creación de hechizos."
				""
				"Cada hechizo debe tener una forma. Comienzas con 3 formas básicas: Proyectil, Autolanzamiento y Toque."
				""
				"Para el Efecto, esto determina lo que sucede cuando lanzas el hechizo. Puedes tener hasta 9 efectos por hechizo."
				""
				"Para empezar, tienes Harm and Break."
				""
				"Selecciona una forma y un efecto, nombra tu hechizo y haz clic en crear."
				""
			]
		}
		quest.441C0659ED28D935.quest_desc: {
			new: ["Tier 1 Glyphs require 3 levels of experience to be made."]
			old: ["Los glifos de nivel 1 requieren 3 niveles de experiencia para crearse."]
		}
		quest.151648179684B088.quest_subtitle: {
			new: "Placeable Spells"
			old: "Hechizos colocables"
		}
		quest.33682F4B44950123.title: {
			new: "&9Archwood"
			old: "Troncos de arco"
		}
	}
	"chapters/mekanism.snbt": {
		quest.7CC49360D07086B8.quest_desc: {
			new: ["&o\"Through using highly detailed Atomic Machinery we can take all Matter apart to the molecular level and move those molecules through specific wave lengths...\"&r Oh come on this is just Magic! \\nWith 2 &5Quantum Entangloporters&r we can Wirelessly move &eItems&f, &bFluids&f, &cChemicals&f, &6Heat&f, and &aEnergy&r! \\n\\nFirst, we need to connect the &5Quantum Entangloporters&r. We do this by going into the Text Bar of one, and typing out a Network name. \\n\\nIt can be Numbers, Letters, Symbols, whatever just Type it and hit the Checkmark Button! Then, go into the second &5Quantum Entangloporter&r and Click the name of the Set Network Name. Now they are connected. \\n\\nAfter that, Connect your &bPipes&f, &cTubes&f, &aCables&r whatever, to a &5Quantum Entangloporter&r and place more or even a &5Machine&r to the other one. \\n\\nOnce that is all ready, change the Side Configs in order to actually move our things around. Don't forget to set Auto-Eject!"]
			old: [
				"This item is how you make Wireless Transfers possible."
				""
				"You can set specific channels, named by you, to transfer whatever you want from it."
			]
		}
		quest.58B125BD4876054C.title: {
			new: "&5&lMekanism&r"
			old: "&dMekanism&r"
		}
		quest.0650996C7818ADB5.quest_desc: {
			new: ["The &6&lHeat Generator&r has 2 modes to generate &aEnergy&r. \\n\\nPassive: Surrounding the &6&lGenerator&r with &cLava Source&r or flowing blocks creates passive &aEnergy&r by creating &6Heat&r. \\n\\nPlace one &cLava Source Block&r on top, and let it flow over the sides. \\n\\nMake sure to connect &bPipes&r first!\\n\\nActive: Placing combustible materials such as &0Coal&r or &6Wood&r into the &6&lGenerator&r will burn the fuel to create &cEnergy&r. \\n\\nIt now creates 320FE/t."]
			old: [
				"The Heat Generator has 2 modes to generate power:"
				""
				"&9Passive:&r Surrounding the generator with lava source or flowing blocks creates passive power by creating heat. Place one lava source block on top, and let it flow over the sides. Make sure to connect pipes first!"
				""
				"&9Active:&r Placing combustible materials such as coal or wood into the generator will burn the fuel to create power."
			]
		}
		quest.0F326EEEC2EBE4E5.quest_desc: {
			new: [
				"Using the &d&lEnrichment Chamber&r, you can &dEnrich &eItems&r to convert them into &dEnriched&r variants."
				""
				"These &dEnriched Items&r give 8x the amount of mb in a &9&lMetallurgic Infuser&r."
				""
				"&dEnriched &0Coal&r will help make more &8Steel&r. &dEnriched &4Redstone&r will help with &cInfused Alloys&r and &aBasic Control Circuits&r. And &dEnriched &5Refined Obisidian&r will help make &dUltimate&r Items!"
			]
			old: [
				"Using the Enrichment Chamber, you can enrich items to convert them into Enriched variants."
				""
				"These \"Enriched\" items give 8x the amount of mb in a Metallurgic Infuser."
				""
				"If you plan on making a bunch of steel, Enrich your Charcoal first!"
			]
		}
		quest.7778937DF377C1B4.quest_desc: {
			new: [
				"This is a great option for automatically generating &aEnergy&r."
				""
				"The amount of &aEnergy&r the &b&lWind Generator&r creates is based on its Y Level."
				""
				"This generates around 90FE/t at sea level and the most it can produce is 360FE/t!"
				""
				"The &b&lWind Generator&r will also need &bSky&r above it to work, like a Beacon!"
			]
			old: [
				"This is a great option for generating power."
				""
				"This generates around 40FE/t, and increases based on how high you are. The higher the Y level, the more power it produces!"
			]
		}
		quest.08DDE018A804BFE7.quest_desc: {
			new: ["The &d&lEnrichment Chamber&r will &dEnrich &eItems&r that go through it. Just place the &eItems&r in the &4Red Slots&r and the &dEnriched Items&r will come out of the &9Blue Slots&r. \\n\\nWhat is an &dEnriched Item&r? Or what happens when an &eItem&r gets &dEnriched&r? Either we get more of it the &eItems&r it can be made into or change the &eItem&r themselves! \\n\\nWe can get 2 Dust from 1 Ore. We can get more Dyes from one Flower. We can even change &6Copper&r Stages or take &2Moss&r off &7Cobblestone&r! \\n\\nWith later Tiers of &d&lEnrichment Chambers&r we get even more Slots to &dEnrich&f more &eItems&r at once. \\n\\nWe also get the ability to Auto-Sort. With the press of this Button! We can set it so the Stacks of &eItems&r will be evenly distributed to each Slot so the &d&lMachine&r is more Efficient."]
			old: [
				"This machine works like a Macerator or Pulverizer, and will break ores down into dusts."
				""
				"This breaks 3 raw ores down into 4 dusts."
				""
				"This is the start of your Ore Factory. It can also be upgraded to a factory machine, increasing the slots of use."
			]
		}
		quest.166971866A9234C7.quest_desc: {
			new: ["One of the 3 most important Infused Items is the &cInfused Alloy&r. \\n\\nTo make it we'll need to Infuse a &6Copper Ingot&r with 10mB of &4Redstone&r. \\n\\nHow do we get 10mB of &4Redstone&r you ask? By placing a &4Redstone Item&r into the &eYellow Square&r of the &9&lMetallurgic Infuser&r! \\n\\nWe'll lose the &4Redstone Item&r and different &4Items&r give different amounts. &4Redstone Dust&r gives 10mB, &4Enriched Redstone&r gives 80mB, and a &4Block of Redstone&r gives 90mB."]
			old: ["Infusing Iron with Redstone in a Metallurgic Infuser will get you one of these."]
		}
		quest.74200A48498DD7F8.quest_subtitle: {
			new: "Generates about 60FE/t"
			old: "Produces about 17.6FE/t"
		}
		quest.0F326EEEC2EBE4E5.title: {
			new: "&dEnriched Items"
			old: "Enriched Items"
		}
		quest.4EDD96EB60EF5814.quest_desc: {
			new: ["If you're wondering if it is worth making this upgrade, the answer is yes.\\n\\n&e&l&oAdvanced Solar Generators&r will take up more Space and are expensive to Craft but will Generate so much more &aEnergy&r. \\n\\nThey work the same as normal &e&lSolar Generators&r, &eDaytime&f and need &bSky&r Exposure. \\n\\nThese can hold 100kFE! \\n\\nYou can also add them on top of &6&lThermal Evaporation Plants&r to produce more &6Heat&r."]
			old: [
				"If you're wondering if it is worth making this upgrade, the answer is yes."
				""
				"This version produces 105.6FE/t. It also can be used to add extra heat to Thermal Evaporation Plants."
			]
		}
		quest.195729280394ABFB.quest_desc: {
			new: ["The &7&lMachine&r creates two really strong ingots: &eRefined Glowstone&f and &5Refined Obsidian&r.\\n\\nIt &7Infuses&r an &eItem&r with &7Osmium&r to create a more powerful Ingot. \\n\\nWe'll need to place &7Osmium Ingots&f, &7Osmium Blocks&f, or a &cChemical Tank&f with &7Osmium Chemical&r in it to feed the &l&7Compressor&r &7Osmium&r!"]
			old: [
				"The machine creates two really strong ingots: Refined Glowstone and Refined Obsidian."
				""
				"It infuses an item with Osmium to create a more powerful ingot."
			]
		}
		quest.58B125BD4876054C.quest_desc: {
			new: ["&5&lMekanism&r is a tech mod that will change the way you play &2&lMinecraft&r. \\n\\nThe mod focuses on breaking down materials to their chemical makeup, and getting the best out of every material you come across.\\n\\nThis mod features Hydrogen-Powered &cJetpacks&r, a mini-robotic friend, &2&lReactors&r, a &7&lDigital Miner&r to automate mining, and much, much more. \\n\\nTrust me, you'll see why it is used in almost every &6&lATM Modpack&r!"]
			old: [
				"Mekanism is a tech mod that will change the way you play Minecraft."
				""
				"The mod focuses on breaking down materials to their chemical makeup, and getting the best out of every material you come across. "
				""
				"This mod features Hydrogen-Powered Jetpacks, a mini-robotic friend, reactors, a Digital Miner to automate mining, and much, much more."
			]
		}
		quest.5E116409DC7D30BB.quest_subtitle: {
			new: "The Configurator"
			old: "Mekanism's Wrench"
		}
		quest.7AE502EDB73BD57A.quest_desc: {
			new: ["The &4&lCrusher&r does as the name suggests! Just like every other Mod's &4Crushers&r... \\n\\nWe can get Dust from Ingots, &7Cobble&r from &7Stone&r, and &2Bio Fuel&r from &2Plants&r! \\n\\nDust will be needed for lots of Recipes so you'll definitely need this. Especially for making &8Upgrades&r!"]
			old: ["This machine crushes ores into their \"dirty\" dust forms. This is useful to convert clumps into dirty dust, which can go through an Enrichment Chamber to create the ore dust, which then can be smelted into an ingot."]
		}
		quest.74200A48498DD7F8.quest_desc: {
			new: ["The &e&lSolar Generator&r will Generate &aEnergy&r based on being exposed to the &bSky&r during &eDaytime&r. \\n\\nIt is a very simple to use automatic &e&lGenerator&r, just Crafting them is annoying! \\n\\nThey won't generate &aEnergy&r as much as &b&lWind Generators&r do (only Daytime) but produce more in Bursts and take up less Space! \\n\\nThey have been buffed and can now hold around 40kFE!"]
			old: ["Generates power from the sun!"]
		}
		quest.6F62B5510FA881CD.title: {
			new: "&7Osmium"
			old: "Osmium"
		}
		quest.0498A578D0EC3254.quest_desc: {
			new: ["The last of the important Infused Items is the &aBasic Control Circuit&r. \\n\\nThese ones are made by combining 20mB of &4Redstone&r with an &7Osmium Ingot&r. \\n\\nCheck out the &cInfused Alloy Quest&r to learn how to add &4Redstone&r to the &9&lMetallurgic Infuser&r!"]
			old: ["Infusing Osmium with Redstone in a Metallurgic Infuser will create you one of these."]
		}
		quest.5E116409DC7D30BB.quest_desc: {
			new: ["You should know Logistics by know! This Quest will now be reserved to explaining the &3Configurator&r! \\n\\nBy Holding Shift and Scrolling you can change the Mode of the &3Configurator&r. \\n\\n&dWrench&r: will Drop &5&lMekanism&r &5Machines&r and Blocks when used on them. \\n&eRotate&r: will simply Rotate the direction of the Block. \\n&4Empty&r: will make it work like a Gauge Dropper. \\nThe rest of them will make the &3Configurator&r interact with&5 Machines&r to change their Configs! \\n\\nIf you use it on Pipes it will change if they Push, Pull, or Both. You can use it on Ports to set Inputs and Outputs. And even on Bins to set them to Auto-Export below them."]
			old: ["This item is used to configure many of the items in Mekanism, from changing pipes to \"Pull or Push\" or rotating machines."]
		}
		quest.7B0DFA55B4D8B16D.quest_desc: {
			new: [
				"&a&lTeleporters&r will allow us to Teleport anywhere in any Dimension as long as the &5Machine&r is made and &aPowered&r! \\n\\nNow how do we make it and Power it? \\n\\nFirst, to make the &a&lTeleporter&r we'll need 1 &aTeleporter Block&f and 9 &aTeleporter Frames&r. \\n\\nThe &aTeleporter Block&r is the main &aController&r of the &a&lTeleporter&r. It is the Block that will need &aEnergy&r, and once &aPowered&r we can open it. Here we can set a Network similar to the &5Quantum Entangloporter&r, type in a name and click the Checkmark to make the Network! \\n\\nNow when other &a&lTeleporter Structures&r or &aTeleporter Blocks&r, are set to that Network (by clicking the named Network in their GUI) you can use the &a&lTeleporter&r to obviously Teleport to the other &a&lTeleporters&r at the same Network. \\n\\nNow about making the &a&lTeleporter Structure&r. Place a &aTeleporter Frame&r on each side of the &aTeleporter Block&r. Above those place 3 more to make it 4 Blocks high. With 2 Blocks space above the &aTeleporter Block&r, you can place our last &aTeleporter Frames&r. \\n\\nNow when Powered and set, the &a&lTeleporter&r will be ready and you can walk through whatever colored Portal spawned! \\n\\n(You can change the Color for each in the &a&lTeleporter&r GUI!)"
				"{@pagebreak}"
				"{image:atm:textures/questpics/mek/meka_portal1.png width:200 height:75 align:center}"
				"Place the &aTeleporter Block&r with 2 &aTeleporter Frames&r next to it."
				"{image:atm:textures/questpics/mek/meka_portal2.png width:150 height:125 align:center}"
				"Now place &aTeleporter Frames&r on the previous ones."
				"{image:atm:textures/questpics/mek/meka_portal3.png width:100 height:125 align:center}"
				"Repeat."
				"{image:atm:textures/questpics/mek/meka_portal4.png width:100 height:140 align:center}"
				"Now, we'll need a whole row of &aTeleporter Frames&r for the top."
				"{image:atm:textures/questpics/mek/meka_portal5.png width:110 height:150 align:center}"
				"Once everything is set, the Portal of your choosing should appear like so!"
			]
			old: [
				"To create a custom Portal, place down a single Teleporter block. Connect power to the block."
				""
				"Create a \"Portal Frame\" with the teleporter block being the base of the portal."
				""
				"The final product will be a 4x3 portal structure, with the two blocks in the middle creating the portal."
			]
		}
		quest.7B0DFA55B4D8B16D.quest_subtitle: {
			new: "Teleportation at its Finest"
			old: "Teleportation at its finest."
		}
		quest.488DBE69595F38F8.quest_desc: {
			new: ["No, no, no, no, no more using &0Coal&r to power our Furnaces, we need &0Coal &ffor &8Steel&r! \\n\\nHere use the &6&lEnergized Smelter&r instead! It uses &aEnergy&r to &6Smelt&e Items&r! \\n\\nIt can also be Upgraded to contain more Slots for more &6Smelting&r, kinda like a Jumbo Furnace. \\n\\nUpgraded &lTiers&r will also have an Auto-Sort button. This allows the &6&lMachine&r to automatically distribute the &eItems&r evenly among the Slots to be more efficient!"]
			old: [
				"This machine smelts items."
				""
				"It can be upgraded into a Smelting Factory, increasing the total number of smelting slots up to a maximum of 9."
			]
		}
		quest.162CE44400A63575.quest_desc: {
			new: ["The first and most important &5Machine&r is the &9&lMetallurgic Infuser&r! \\n\\nThe &9&lMetallurgic Infuser&r will combine an &eItem&r and a &cChemicals&r to Craft new &eItems&r and Alloys. \\n\\n&cChemicals &for &aInfuse Types&r will go into the &eYellow Square&r and will show up in the &eBar&r to the Left of it. \\n\\nThe &4Red Square&r will hold the Item that gets Infused. \\n\\nThe &9Dark Blue Square&r will be where the product goes to! \\n\\nTo the Right, the &aLight Green Slot&r and &aBar&r are for &aEnergy&r! \\n\\nIf you need to make room in the &eChemical Bar&r, use the &lDUMP&r Button. This will eject all &aChemicals&r in it!"]
			old: [
				"The Metallurgic Infuser is used to craft core crafting components throughout Mekanism."
				""
				"The machine works by infusing a material (middle-left slot) with an \"infuser\" (far-left slot)."
				""
				"This is also how you get Steel Ingots."
			]
		}
		quest.6CD1720B76F47806.quest_desc: {
			new: ["The &2&lBio-Generator&r works by taking &2Bio Fuel&r, making &2Bioethanol&r, and using that for &aEnergy&r! \\n\\nThis &2&lGenerator&r has been heavily nerfed though, so it is recommened to not use it! \\n\\nThat is because you buttheads keep making massive &aMelon Farms&r that eat Servers TPS!"]
			old: ["This generator will burn Bio Fuel into energy. It produces around 140FE/t."]
		}
	}
	"chapters/applied_energistics_2.snbt": {
		quest.1348995F64A94396.quest_desc: {
			new: ["The &bCrafting Monitor&f displays the overall item being crafted, along with the remaining quantity of that item still being crafted.\\n\\nBoth the base AE2 monitor and the MEGA monitor function identically, but are provided for aesthetic purposes."]
			old: [
				"La &bUnidad de coprocesamiento de elaboración&f ayuda a acelerar los trabajos de elaboración al permitir que los proveedores de patrones envíen elementos a sus dispositivos conectados más rápido o trabajen simultáneamente para fabricar los Múltiples ingredientes necesarios."
				""
				"El coprocesador AE2 básico proporciona un \"hilo\" de coprocesador para ayudar con esto, mientras que la unidad de coprocesamiento de &dMEGA Cells&f proporciona 4 hilos en un solo bloque de este tipo."
			]
		}
		quest.2077D64428E9C067.quest_desc: {
			new: [
				"An important concept within AE2 is a technique known as '&esubnetting&f', wherein an extra separate ME network (a &esubnetwork&f) acts in conjunction with the main network to perform some specialised function or process. "
				""
				"What separates a subnetwork from a completely detached separate network is usually the use of the &bQuartz Fiber&f as a cable part. When placed between two otherwise unconnected lengths of cable, the Quartz Fiber transfers no data or channels between the two whatsoever, instead only transmitting power. "
				""
				"Thus, a subnetwork on the other side of the Fiber can be powered wholly by the main network's power source, without requiring any extra dedicated powergen."
			]
			old: [
				"An important concept within AE2 is a technique known as \"&esubnetting&f\", wherein an extra separate ME network (a &esubnetwork&f) acts in conjuction with the main network to perform some specialised function or process."
				""
				"What separates a subnetwork from a completely detached separate network is usually the use of the &bQuartz Fiber&f as a cable part. When placed between two otherwise unconnected lengths of cable, the Quartz Fiber transfers no data or channels between the two whatsoever, instead only transmitting power."
				""
				"Thus, a subnetwork on the other side of the Fiber can be powered wholly by the main network's power source, without requiring any extra dedicated powergen."
			]
		}
		quest.2893F483C10293E6.quest_desc: {
			new: [
				"&lWelcome to &bApplied Energistics 2&f!\\n\\nApplied Energistics 2 (or &oAE2&r for short) is an incredibly versatile &bdigital storage&f mod, allowing for extremely efficient storage and all sorts of automation capabilities to greatly augment your modded Minecraft experience from as early as you want to the very endgame.\\n\\nFor more information on AE2 beyond this chapter, consult the wiki over at"
				"&o&bappliedenergistics.github.io&f&r."
			]
			old: [
				"&lBienvenido a &bApplied Energistics 2&f!"
				""
				"Applied Energistics 2 (o &oAE2&r para abreviar) es un mod de &balmacenamiento digital&f increíblemente versátil, que permite un almacenamiento extremadamente eficiente y todo tipo de capacidades de automatización para aumentar enormemente tu experiencia de Minecraft modificada desde el principio hasta el final del juego."
				""
				"Para comenzar con AE2, necesitarás extraer un recurso importante para el mod conocido como &bCuarzo Certus&f. Al igual que con la amatista, encontrarás cristales de cuarzo Certus que puedes extraer para &ePolvo&f y &eCristales&f de cuarzo Certus."
				""
				"Para obtener más información sobre AE2 más allá de este capítulo, consulta la wiki en &o&bappliedenergistics.github.io&f&r."
			]
		}
		quest.33ADE41526C39AFD.quest_desc: {
			new: ["This behaviour is comparable to something like a Functional Storage drawer, wherein each compartment holds a set number of stacks as opposed to allowing items from one compartment to leak into the others and crowd other kinds of items out."]
			old: ["The &bOverflow Destruction Card&f is a cell upgrade that allows storage cells to delete (void) any items of a type already contained within them, when try to move into the cell and the cell is already full."]
		}
		quest.78311531069807DE.quest_desc: {
			new: ["In Applied Energistics 2, every ME network has a certain number of &echannels&f available, which simply means how many networked devices can fit on the whole network.\\n\\nAs a rule of thumb, any device that more or less handles ME data directly (items stored within the network) and carries out some form of I/O will take up a channel. Usually components that are only concerned with the internal power storage of the network, like &eEnergy Cells&f and &eInscribers&f, do &onot&r take up channels.\\n\\nNetworks without an &bME Controller&f are known as 'ad-hoc' networks and only support a maximum of 8 channels."]
			old: [
				"En Applied Energistics 2, cada red ME tiene una cierta cantidad de &ecanales&f disponibles, lo que simplemente significa cuántos dispositivos en red caben en toda la red."
				""
				"Como regla general, cualquier dispositivo que maneje datos ME de manera más o menos directa (elementos almacenados dentro de la red) y lleve a cabo algún tipo de E/S ocupará un canal. Por lo general, los componentes que solo se ocupan del almacenamiento de energía interno de la red, como &eCeldas de energía&f y &eInscriptores&f, &onot&r ocupan canales."
				""
				"Las redes sin un &bControlador ME&f se conocen como redes \"ad-hoc\" y solo admiten un máximo de 8 canales."
			]
		}
		task.14DEFFB80CC96BC1.title: {
			new: "ME Dense Covered Cables"
			old: "Dense Covered Cable"
		}
		quest.3195A7AA874163CD.quest_desc: {
			new: ["The &bEqual Distribution Card&f is an upgrade for storage cells that pre-allocates a certain amount of items that can be taken up by any individual type.\\n\\nThis behaviour is comparable to something like a Functional Storage drawer, wherein each compartment holds a set number of stacks as opposed to allowing items from one compartment to leak into the others and crowd other kinds of items out."]
			old: [
				"The &bEqual Distribution Card&f is an upgrade for storage cells that pre-allocates a certain amount of items that can be taken up by any individual type."
				""
				"This behaviour is comparable to something like a Functional Storage drawer, wherein each compartment holds a set number of stacks as opposed to allowing items from one compartment to leak into the others and crowd other kinds of items out."
			]
		}
		quest.140DE53DC0FCD9F4.quest_desc: {
			new: [
				"The &bME Annihilation Plane&f can be used to automatically break any blocks in front of it and return anything dropped by the block directly to the ME network. "
				""
				"As an added bonus, the Annihilation Plane can be enchanted in the same way as a regular digging tool, affecting block drops in the same way as that enchanted tool would. This makes it ideal for processing ore blocks when enchanted with Fortune, for example. "
				"Any added enchantments significantly increase the amount of energy used by the plane every time a block is broken. Enchanting the plane with &eEfficiency&f will decrease the overall energy use incurred by all other enchantments, while the &eUnbreaking&f enchantment gives the plane the chance to only use any energy sometimes, similarly to Unbreaking on regular tools."
			]
			old: [
				"The &bME Annihilation Plane&f can be used to automatically break any blocks in front of it and return anything dropped by the block directly to the ME network."
				""
				"As an added bonus, the Annihilation Plane can be enchanted in the same way as a regular digging tool, affecting block drops in the same way as that enchanted tool would. This makes it ideal for processing ore blocks when enchanted with Fortune, for example."
				""
				"Any added enchantments significantly increase the amount of energy used by the plane every time a block is broken. Enchanting the plane with &eEfficiency&f will decrease the overall energy use incurred by all other enchantments, while the &eUnbreaking&f enchantment gives the plane the chance to only use any energy sometimes, similarly to Unbreaking on regular tools."
			]
		}
		quest.22C4318523A43B49.quest_desc: {
			new: ["&eTerminals&f provide access to any of the contents of an ME network. The standard &eME Terminal&f simply lists everything in the network as one large grid to pull from and insert into, akin to a single inventory.\\n\\nThe &eME Crafting Terminal&f is an extension of the ME Terminal which also provides a built-in crafting grid, allowing for convenient crafting using any item contained in the network and visible through the terminal screen."]
			old: [
				"Las &eTerminales&f brindan acceso a cualquiera de los contenidos de una red ME. La &eTerminal ME&f estándar simplemente enumera todo lo que hay en la red como una gran cuadrícula de la que extraer e insertar, similar a un único inventario."
				""
				"La &eTerminal de trabajo ME&f es una extensión de la Terminal ME que también proporciona una cuadrícula de creación integrada, lo que permite crear objetos de manera conveniente utilizando cualquier elemento contenido en la red y visible a través de la pantalla de la terminal."
			]
		}
		quest.2F556E7919582D2D.quest_desc: {
			new: ["The &bCell Workbench&f allows for cells to be 'partitioned' to hold specific items, i.e. given a whitelist filter. It also allows the cell to be upgraded with certain upgrade cards such as the Inverter Card, which sets the aforementioned whitelist to be a blacklist instead.\\n\\nCells can also be given a higher or lower 'priority' via the workbench, i.e. allow the cell to be the first to receive certain items until full, or made to wait for other higher-priority cells to fill up first."]
			old: [
				"The &bCell Workbench&f allows for cells to be \"partitioned\" to hold specific items, i.e. given a whitelist filter. It also allows the cell to be upgraded with certain upgrade cards such as the Inverter Card, which sets the aforementioned whitelist to be a blacklist instead."
				""
				"Cells can also be given a higher or lower \"priority\" via the workbench, i.e. allow the cell to be the first to receive certain items until full, or made to wait for other higher-priority cells to fill up first."
			]
		}
		quest.51DE3157DE3E57B8.quest_desc: {
			new: [
				"Storage is nice and all that, but what good is a storage system if it's clogged up with raw materials needing to be crafted and processed into something and you're still stuck with having to do so manually? "
				""
				"AE2's &eauto-crafting&f system begins with the &bME Pattern Provider&f. The Pattern Provider holds certain items called &bPatterns&f (covered in the next quest) which are programmed to hold some recipe that turns input items into a certain output. Up to 9 patterns can fit in one provider. "
				""
				"You'll often be making use of multiple pattern providers scattered all throughout your base, which is why it's useful to have a &bPattern Access Terminal&f to remotely access the contents of any and all providers on your wider ME network."
			]
			old: [
				"El almacenamiento es bueno y todo eso, pero ¿de qué sirve un sistema de almacenamiento si está obstruido con materias primas que necesitan ser elaboradas y procesadas para convertirse en algo y aún así estás atascado con tener que hacerlo manualmente?"
				""
				"El sistema de &eauto-elaboración&f de AE2 comienza con el &bProveedor de patrones ME&f. El Proveedor de patrones contiene ciertos elementos llamados &bPatrones&f (que se tratan en la siguiente misión) que están programados para contener alguna receta que convierte elementos de entrada en un determinado resultado. Hasta 9 patrones pueden caber en un proveedor."
				""
				"A menudo harás uso de múltiples proveedores de patrones dispersos por toda tu base, por lo que es útil tener una &bTerminal de acceso a patrones&f para acceder de forma remota al contenido de todos y cada uno de los proveedores de tu red ME más amplia."
			]
		}
		quest.5C22E3103544B120.quest_desc: {
			new: ["To connect the vast majority of your ME network together, you will need some cable. &eME Glass Cable&f is the first and most basic kind of cable, and you'll be making this all throughout as the first step towards crafting the other kinds of cable.\\n\\nBoth glass cables and their &ecovered&f counterpart can carry up to 8 channels along a single section of cabling. Unlike glass cables, covered cables can subsequently be crafted into &edense&f covered cables, capable of carrying up to 32 channels. However, most 'multipart' devices such as buses and terminals cannot be directly attached to dense cables, requiring normal-width cables to form a connection instead.\\n\\nAll cables can also be crafted with dye to colour them. Uncoloured ('Fluix') cables can connect to any other colour of cable, but otherwise differently-coloured cables will never connect to one another."]
			old: [
				"Para conectar la gran mayoría de su red ME, necesitará algún cable. El &eCable de Vidrio ME&f es el primer tipo de cable y el más básico, y lo fabricará como primer paso para fabricar los otros tipos de cable."
				""
				"Tanto los cables de vidrio como sus contrapartes &ecubiertas&f pueden transportar hasta 8 canales a lo largo de una sola sección de cableado. A diferencia de los cables de vidrio, los cables cubiertos pueden transformarse posteriormente en cables cubiertos &edensos&f, capaces de transportar hasta 32 canales. Sin embargo, la mayoría de los dispositivos \"multiparte\", como buses y terminales, no se pueden conectar directamente a cables densos, por lo que requieren cables de ancho normal para formar una conexión."
				""
				"Todos los cables también se pueden fabricar con tinte para colorearlos. Los cables sin color (\"Fluix\") se pueden conectar a cualquier otro color de cable, pero los cables de otro color nunca se conectarán entre sí."
			]
		}
		quest.037488EF1F3581CE.quest_desc: {
			new: ["By default, an ME network on its own only has an internal buffer of 800AE without an ME Controller, with the controller adding an extra 8kAE per block. For large enough networks, this can be insufficient and may cause a network to power off intermittently when trying to recoup power for any connected devices.\\n\\nThe &bEnergy Cell&f allows for an ME network to hold significantly more energy, adding another 200kAE per regular Energy Cell and 1.6MAE per &bDense&f Energy Cell. These can also be placed anywhere in the network to provide the increased energy buffer."]
			old: [
				"De manera predeterminada, una red ME por sí sola solo tiene un búfer interno de 800 AE sin un controlador ME, y el controlador agrega 8 kAE adicionales por bloque. Para redes lo suficientemente grandes, esto puede ser insuficiente y puede provocar que una red se apague de manera intermitente al intentar recuperar energía para cualquier dispositivo conectado."
				""
				"La &bcelda de energía&f permite que una red ME contenga significativamente más energía, agregando otros 200 kAE por celda de energía regular y 1,6 MAE por celda de energía &bdensa&f. Estas también se pueden colocar en cualquier parte de la red para proporcionar el búfer de energía aumentado."
			]
		}
		quest.1AAF0B31B47AF23D.quest_desc: {
			new: ["Individual ME devices can also be configured to respond to redstone signals. When upgraded with a &bRedstone Card&f, a device can be configured to do work only when powered with redstone or otherwise as needed.\\n\\nThis behavior can also apply to entire &osections&r of an ME network by using an &bME Toggle Bus&f. This allows a section of the network on the other side of the bus to come online only when the bus is powered by redstone, or to go offline if using an &einverted&f toggle bus."]
			old: [
				"Individual ME devices can also be configured to respond to redstone signals. When upgraded with a &bRedstone Card&f, a device can be configured to do work only when powered with redstone or otherwise as needed."
				""
				"This behavour can also apply to entire &osections&r of an ME network by using an &bME Toggle Bus&f. This allows a section of the network on the other side of the bus to come online only when the bus is powered by redstone, or to go offline if using an &einverted&f toggle bus."
			]
		}
		quest.2B31E6C1707D8195.quest_desc: {
			new: ["The next thing to make to allow for wireless network access is the &bME Wireless Access Point&f. The Access Point is used to open the network to wireless access via a &ewireless terminal&f, and has a set (finite) range depending on how many &bWireless Boosters&f are inserted into the access point."]
			old: ["El siguiente paso para permitir el acceso a la red inalámbrica es el &bME Wireless Access Point&f. El punto de acceso se utiliza para abrir la red al acceso inalámbrico a través de un &ewireless terminal&f, tiene un alcance fijo (finito) que depende de cuántos  &bWireless Boosters&f se inserten en el punto de acceso. "]
		}
		quest.525F25F4ADE45B50.quest_desc: {
			new: [
				"The &bME Formation Plane&f acts similarly to the Storage Bus, but treats the world itself as its storage medium. In other words, it will place down any block in its filter directly in front of itself. "
				""
				"This can be useful for situations where a block can be processed simply by placing it and breaking it with a certain tool."
			]
			old: [
				"The &bME Formation Plane&f acts similarly to the Storage Bus, but treats the world itself as its storage medium. In other words, it will place down any block in its filter directly in front of itself."
				""
				"This can be useful for situations where a block can be processed simply by placing it and breaking it with a certain tool."
			]
		}
		task.1076BC82EECB73F5.title: {
			new: "Quartz Wrenches"
			old: "Quartz Wrench"
		}
		quest.1B686954D34A0F23.quest_subtitle: {
			new: "Does exactly what you'd expect"
			old: "Hace exactamente lo que esperas."
		}
		quest.0B218DD73FE8D985.quest_desc: {
			new: ["If you did that last quest correctly, you should have turned that singularity into a pair of &bQuantum Entangled Singularities&f. These new singularities are used to link together a ring-shaped device known as a &eQuantum Network Bridge&f.\\n\\nWhen two of these individual rings have been linked using the Quantum Entangled Singularities and jumpstarted with some AE power (e.g. an energy cell), an ME network can be expanded wirelessly on the other side of the bridge, across either long distances or even dimensions."]
			old: [
				"If you did that last quest correctly, you should have turned that singularity into a pair of &bQuantum Entangled Singularities&f. These new singularities are used to link together a ring-shaped device known as a &eQuantum Network Bridge&f."
				""
				"When two of these individual rings have been linked using the Quantum Entangled Singularities and jumpstarted with some AE power (e.g. an energy cell), an ME network can be expanded wirelessly on the other side of the bridge, across either long distances or even dimensions."
			]
		}
		quest.55186B8602689B66.quest_desc: {
			new: [
				"The &bMemory Card&f is a tool with two different functions. The simplest of the two is to save various devices' configurations (such as whitelist filters) to be copied over to another device of the same kind. "
				""
				"The second function of a memory card is to link &eP2P tunnels&f together. When doing so, the P2P tunnel being linked will be assigned a unique ID, which is stored on the memory card for further linking."
			]
			old: [
				"The &bMemory Card&f is a tool with two different functions. The simplest of the two is to save various devices' configurations (such as whitelist filters) to be copied over to another device of the same kind."
				""
				"The second function of a memory card is to link &eP2P tunnels&f together. When doing so, the P2P tunnel being linked will be assigned a unique ID, which is stored on the memory card for further linking."
			]
		}
		quest.1F7DFA5AA65F2812.quest_desc: {
			new: ["The &bAcceleration Card&f, depending on the device being upgraded with it, will either increase the speed at which the device operates or allow the device to carry out more operations in one go.\\n\\nIn the case of the &eMolecular Assembler&f, a full set of 5 cards reduces the time taken for the MA to fulfil a craft from one second (with no cards) to one &otick&r."]
			old: [
				"La &bTarjeta de Aceleración&f, dependiendo del dispositivo que se actualice con ella, aumentará la velocidad a la que opera el dispositivo o permitirá que el dispositivo realice más operaciones a la vez."
				""
				"En el caso del &eEnsamblador Molecular&f, un conjunto completo de 5 tarjetas reduce el tiempo que tarda el MA en completar una tarea de un segundo (sin tarjetas) a un &otick&r."
			]
		}
		quest.4E8A05C3BFA80540.quest_subtitle: {
			new: "Items as a file system"
			old: "Elementos como un sistema de archivos"
		}
		quest.2893F483C10293E6.quest_subtitle: {
			new: "Virtual Storage System"
			old: "Sistema de almacenamiento virtual"
		}
		quest.4E8A05C3BFA80540.title: {
			new: "The Storage"
			old: "El Almacenamiento"
		}
		quest.5E24012A3D9B72A1.quest_desc: {
			new: [
				"Items are not the only things that can be stored in ME cells. &bME Fluid Storage Cells&f can store liquids such as water, lava and any variety of modded oils and fuels, just to give a few examples. "
				""
				"Note that all storage cells, regardless of what they're designed to store, only differ in terms of their housing; both item and fluid cells use the same kind of storage component to make. "
				""
				"For fluids, 1 byte equals 8 buckets (8000mb)."
			]
			old: [
				"Items are not the only things that can be stored in ME cells. &bME Fluid Storage Cells&f can store liquids such as water, lava and any variety of modded oils and fuels, just to give a few examples."
				""
				"Note that all storage cells, regardless of what they're designed to store, only differ in terms of their housing; both item and fluid cells use the same kind of storage component to make."
				""
				"For fluids, 1 byte equals 8 buckets (8000mb)."
			]
		}
		quest.5233A447BAA4593C.quest_desc: {
			new: ["The &bME Smart Cable&f and &bDense Smart Cable&f function identically to the covered cables in terms of channel distribution, but will also visibly display the amount of channels they are using as coloured lines along themselves."]
			old: ["El &bME Smart Cable&f y el &bDense Smart Cable&f funcionan de manera idéntica a los cables cubiertos en términos de distribución de canales, pero también mostrarán visiblemente la cantidad de canales que están utilizando como líneas de colores a lo largo de ellos."]
		}
		quest.4BF0BB763BFFACF0.title: {
			new: "Fluix"
			old: "Fluix Crystal"
		}
		task.75924053D6F5B242.title: {
			new: "Spatial Storage Cells"
			old: "Spatial Storage Cell"
		}
		quest.1710B3D05215A71E.quest_desc: {
			new: [
				"&bP2P&f (peer-to-peer) is a powerful system within AE2, allowing for the transfer of items, fluids and even more without the need for any intermediary ME storage. "
				""
				"Right-clicking on a P2P tunnel with certain items will &eattune&f the tunnel into one capable of transferring something else, such as items through pipes, energy through cables, redstone signals and (by default) even ME connections themselves. "
				""
				"P2P tunnels must be linked to one another with the use of a &eMemory Card&f, detailed in the next quest."
			]
			old: [
				"&bP2P&f (peer-to-peer) is a powerful system within AE2, allowing for the transfer of items, fluids and even more without the need for any intermediary ME storage."
				""
				"Right-clicking on a P2P tunnel with certain items will &eattune&f the tunnel into one capable of transferring something else, such as items through pipes, energy through cables, redstone signals and (by default) even ME connections themselves."
				""
				"P2P tunnels must be linked to one another with the use of a &eMemory Card&f, detailed in the next quest."
			]
		}
		quest.68B0B3DAF1145191.quest_subtitle: {
			new: "First Things First"
			old: "Algunas máquinas básicas"
		}
		quest.3E3DF8E967D95DB0.quest_desc: {
			new: ["When using a 64k storage component or higher, the Matter Condenser becomes able to condense significantly more to produce a &bSingularity&f. A single singularity requires 256000 items to be voided. That's exactly &o4000 stacks&r!\\n\\nSee what happens when you throw this singularity on the ground with a piece of &eEnder Dust&f. You'll have to deal some damage to the surroundings while you're at it, but thankfully AE2 offers its own &bTiny TNT&f to minimise that."]
			old: [
				"When using a 64k storage component or higher, the Matter Condenser becomes able to condense significantly more to produce a &bSingularity&f. A single singularity requires 256000 items to be voided. That's exactly &o4000 stacks&r!"
				""
				"See what happens when you throw this singularity on the ground with a piece of &eender dust&f. You'll have to deal some damage to the surroundings while you're at it, but thankfully AE2 offers its own &bTiny TNT&f to minimise that."
			]
		}
		quest.5AA3E5DFECB4AC4D.quest_desc: {
			new: ["Naturally, AE2 provides its own way to dramatically speed up crystal growth.\\n\\nPlace these around your Budding Crystals, give them some power, and watch your crystals grow!"]
			old: [
				"Naturalmente, AE2 proporciona su propia manera de acelerar drásticamente el crecimiento de los cristales."
				""
				"¡Colóquelos alrededor de sus cristales en ciernes, bríndeles algo de poder y observe cómo crecen sus cristales!"
			]
		}
		quest.22C4318523A43B49.title: {
			new: "Terminals"
			old: "Terminales"
		}
		quest.5E6585F7627247E3.quest_desc: {
			new: ["When applied as an upgrade to any supported device such as an Interface or Export Bus, the &bCrafting Card&f allows the device in question to automatically send out its own crafting requests for a required (filtered) item. Crafting CPUs can be set to respond only to these requests to prevent taking up CPUs meant for player-requested crafts.\\n\\nWhen the &eLevel Emitter&f is upgraded with the Crafting Card, it can be configured to emit redstone in order to directly facilitate in crafting, by emitting a signal either &owhile&r a crafting job for its given item is detected or specifically &oto&r craft the item. The latter would apply for cases where the only thing needed to make a given item is a redstone signal, without even requiring a crafting pattern."]
			old: [
				"Cuando se aplica como una mejora a cualquier dispositivo compatible, como una interfaz o un bus de exportación, la &bTarjeta de creación&f permite que el dispositivo en cuestión envíe automáticamente sus propias solicitudes de creación de un objeto requerido (filtrado). Las CPU de creación se pueden configurar para que respondan solo a estas solicitudes para evitar ocupar las CPU destinadas a las creaciones solicitadas por el jugador."
				""
				"Cuando el &eEmisor de nivel&f se actualiza con la Tarjeta de creación, se puede configurar para que emita piedra roja para facilitar directamente la creación, emitiendo una señal &omientras se detecta un trabajo de creación para su objeto en particular o específicamente &o&r para crear el objeto. Esto último se aplicaría en los casos en los que lo único necesario para crear un objeto determinado es una señal de piedra roja, sin siquiera requerir un patrón de creación."
			]
		}
		quest.5233A447BAA4593C.quest_subtitle: {
			new: "'S.M.R.T.'"
			old: "\"S.M.R.T.\""
		}
		quest.15564C11744D6AA0.quest_desc: {
			new: ["Once you have obtained a full set of the required &eInscriber Presses&r, it's time to start making some &eProcessors&f. These are an important crafting ingredient used to make the large majority of ME-connected devices."]
			old: ["Una vez que haya obtenido un kit completo de las &ePrensas de inscripción&r necesarias, es hora de comenzar a fabricar algunos &eProcesadores&f. Estos son un ingrediente de fabricación importante que se utiliza para fabricar la gran mayoría de dispositivos conectados a ME."]
		}
		quest.2FB231069D2E4E77.quest_desc: {
			new: ["Each individual cell has a certain capacity dictated by the &ecomponent&f that the cell has been crafted with.\\n\\nThe first of the components is the &b1k ME Storage Component&f, providing &e1024&f 'bytes' of storage for a given cell. More on that later."]
			old: [
				"Each individual cell has a certain capacity dictated by the &ecomponent&f that the cell has been crafted with."
				""
				"The first of the components is the &b1k ME Storage Component&f, providing &e1024&f \"bytes\" of storage for a given cell. More on that later."
				""
				"Create the 1k Component, which will be combined with housing in the next quest."
			]
		}
		quest.361CCBD353D6FF34.quest_desc: {
			new: [
				"With the 1k Storage Component, you can now craft yourself a 1k ME Item Storage Cell to start your digital item storage system. You'll most likely want the majority of your storage to be for items, so you'll probably want to make a few &bME Item Storage Cells&f. "
				""
				"ME Item Storage Cells can each hold up to 63 different types of items. Each new type of item added to a cell will take up a certain fraction of the storage cell's total capacity in bytes. For each type already present, 1 'byte' counts for 8 items of that same type. "
				""
				"As an example, a 1k Item Storage Cell containing only cobblestone can hold up to 8128 cobblestone (8*1024b - 8b/type * 1 type). "
				""
				"If a cell is empty, it can be repurposed by disassembling it into its respective component and housing. This is done by sneaking and right-clicking in the air with the cell in your hand."
			]
			old: [
				"With the 1k Storage Component, you can now craft yourself a 1k ME Item Storage Cell to start your digital item storage system. You'll most likely want the majority of your storage to be for items, so you'll probably want to make a few &bME Item Storage Cells&f."
				""
				"ME Item Storage Cells can each hold up to 63 different types of items. Each new type of item added to a cell will take up a certain fraction of the storage cell's total capacity in bytes. For each type already present, 1 \"byte\" counts for 8 items of that same type."
				""
				"As an example, a 1k Item Storage Cell containing only cobblestone can hold up to 8128 cobblestone (8*1024b - 8b/type * 1 type)."
				""
				"If a cell is empty, it can be repurposed by disassembling it into its respective component and housing. This is done by sneaking and right-clicking in the air with the cell in your hand."
			]
		}
		quest.3E3DF8E967D95DB0.quest_subtitle: {
			new: "Hyper-Condensed Matter"
			old: "Not quite antimatter"
		}
		quest.16299B9AE87257DC.quest_desc: {
			new: ["The &bWireless Terminal&f functions identically to a regular terminal, but wirelessly.\\n\\nBefore it can be used to access a network, it must first be &elinked&f to the network by placing it into the top-right slot of the &eWireless Access Point&r. If it is not linked to a network, or is out of either range or power, the terminal will not function.\\n\\nWireless terminals can also be upgraded with &eEnergy Cards&f to provide a larger internal battery."]
			old: [
				"the &bWireless Terminal&f functions identically to a regular terminal, but wirelessly. Go figure."
				""
				"Before a wireless terminal can be used to access a network, it must first be &elinked&f to the network via the &eSecurity Terminal&f you made earlier. If it is not linked to a network, or is out of either range or power, the terminal will not function."
				""
				"Wireless terminals can also be upgraded with &eEnergy Cards&f to provide a larger internal battery."
			]
		}
		quest.03E6FA4DCB71162E.title: {
			new: "Color Applicator"
			old: "Aplicador de color"
		}
		quest.7B7D1F0CB326B28F.quest_desc: {
			new: ["The &bME IO Port&f allows for the contents of an ME network's storage to be quickly rearranged between different storage media such as ME cells and external containers connected to storage buses.\\n\\nWhen a cell is inserted in an input slot on the left, the IO Port can be toggled to either empty the cell out into other ME storages or fill the (ideally, partitioned) cell with certain items spread out across other storages."]
			old: [
				"The &bME IO Port&f allows for the contents of an ME network's storage to be quickly rearranged between different storage media such as ME cells and external containers connected to storage buses."
				""
				"When a cell is inserted in an input slot on the left, the IO Port can be toggled to either empty the cell out into other ME storages or fill the (ideally, partitioned) cell with certain items spread out across other storages."
			]
		}
		quest.03E6FA4DCB71162E.quest_desc: {
			new: ["The &bColor Applicator&f is a chargeable tool that allows for in-world dyeing of cables. It functions more or less as a specialised &estorage cell&f to be loaded up with either vanilla dyes or &epaint balls&f for specific colours, along with &esnowballs&f to wash colours off and turn cables back to their Fluix variant.\\n\\nApplying colour to a cable uses 100AE of energy from its internal battery, for a total of 3400 cable segments in a single charge."]
			old: [
				"El &bAplicador de color&f es una herramienta recargable que permite teñir cables en el mundo real. Funciona más o menos como una &estorage cell&f especializada que se carga con tintes vainilla o &epaint balls&f para colores específicos, junto con &esnowballs&f para lavar los colores y devolver los cables a su variante Fluix."
				""
				"Aplicar color a un cable consume 100 AE de energía de su batería interna, lo que da un total de 3400 segmentos de cable en una sola carga."
			]
		}
		task.61D93B13D496547D.title: {
			new: "Fluid Storage"
			old: "ME Fluid Storage Cell"
		}
		quest.15564C11744D6AA0.title: {
			new: "Processors"
			old: "Procesadores"
		}
		quest.68B0B3DAF1145191.quest_desc: {
			new: ["Two of the very first things you will need to get started in AE2 are the &bCharger&f and the &bInscriber&f.\\n\\nThe &bCharger&f, when supplied with power, will take &eCertus Quartz Crystals&r and charge them. These &eCharged Certus Crystals&r can then be used in the production of &eFluix&f, another important resource in the mod. It can also be used to charge any item that stores power.\\n\\nThe &bInscriber&f can be used to turn the various quartz crystals in AE2 into their dust form, but more importantly is used to fabricate special &ePrinted Circuits&f and &eProcessors&f, as will become clearer in the next quest."]
			old: [
				"Dos de las primeras cosas que necesitarás para empezar en AE2 son el &bCargador&f y la &bPrensa&f."
				""
				"El &bCargador&f, cuando se le suministra energía, tomará &eCristales de cuarzo Certus&r y los cargará. Estos &eCristales de cuarzo Certus cargados&r pueden usarse para producir &eFluido&f, otro recurso importante del mod. También puede usarse para cargar cualquier elemento que almacene energía."
				""
				"La &bPrensa&f puede usarse para convertir los diversos cristales de cuarzo en AE2 en su forma de polvo, pero lo más importante es que se usa para fabricar &eCircuitos impresos&f y &eProcesadores&f especiales, como se aclarará en la siguiente misión."
			]
		}
		quest.5BB887411B8B38FA.quest_desc: {
			new: ["As for wirelessly expanding the ME Network itself, the first step is admittedly somewhat unorthodox.\\n\\nThe &bMatter Condenser&f is AE2's take on a trash can, voiding any items inserted into it. When fitted with a &eStorage Component&f, however, the condenser can harness some left-over energy from the item being voided and store it to make two special crafting items out of enough concentrated energy.\\n\\nThe first of these two items is the &bMatter Ball&f, requiring at least a 1k storage component and 256 items' worth of voided material."]
			old: [
				"As for wirelessly expanding the ME Network itself, the first step is admittedly somewhat unorthodox."
				""
				"The &bMatter Condenser&f is AE2's take on a trash can, voiding any items inserted into it. When fitted with a &eStorage Component&f, however, the condenser can harness some left-over energy from the item being voided and store it to make two special crafting items out of enough concentrated energy."
				""
				"The first of these two items is the &bMatter Ball&f, requiring at least a 1k storage component and 256 items' worth of voided material."
			]
		}
		quest.234DC1702333EB18.title: {
			new: "Infinity Booster"
			old: "AEInfinityBooster"
		}
		quest.74FC0DDDB91DB172.quest_desc: {
			new: ["To make life that much easier, AE2 provides a whole suite of devices for the manipulation of ME data, i.e. moving stored items around the world.\\n\\nThe &bME Interface&f is one of these devices. As an input device, the Interface allows any item/fluid/etc to be piped externally through it, which is then automatically stored in the ME Network that the interface is connected to.\\n\\nAs an output device, the Interface can be configured to keep a certain available amount of a stored item in stock, from the ME network to its own internal inventory. This allows items to then be received by some external source like another player or some pipe."]
			old: [
				"To make life that much easier, AE2 provides a whole suite of devices for the manipulation of ME data, i.e. moving stored items around the world."
				""
				"The &bME Interface&f is one of these devices. As an input device, the Interface allows any item/fluid/etc to be piped externally through it, which is then automatically stored in the ME Network that the interface is connected to."
				""
				"As an output device, the Interface can be configured to keep a certain available amount of a stored item in stock, from the ME network to its own internal inventory. This allows items to then be received by some external source like another player or some pipe."
			]
		}
		quest.3DDB0DDA7571B2C1.quest_desc: {
			new: ["The &bME Level Emitter&f, when configured with a specific item and quantity of it to respond to, will emit a redstone signal depending on whether that item stored in the network either falls below, goes above or equals the given quantity.\\n\\nThis can be used, for example, to automatically switch certain machines on with redstone to auto-craft a resource when it falls below a given minimum amount."]
			old: [
				"El &bEmisor de nivel ME&f, cuando se configura con un elemento específico y una cantidad del mismo a la que responder, emitirá una señal de redstone dependiendo de si ese elemento almacenado en la red está por debajo, por encima o es igual a la cantidad dada."
				""
				"Esto se puede usar, por ejemplo, para encender automáticamente ciertas máquinas con redstone para que fabriquen automáticamente un recurso cuando esté por debajo de una cantidad mínima dada."
			]
		}
		task.40A7CC56DACC2623.title: {
			new: "ME Glass Cables"
			old: "Glass Cable"
		}
		quest.7EFBAF3E281D2EBE.quest_desc: {
			new: [
				"The &bME Storage Bus&f, when facing some external storage container, will allow the container to be used as though it were part of the ME network, allowing items to be taken out from the container or inserted into it purely via ME. "
				""
				"Storage buses can be filtered and given specific priorities such that specific items will try to go to the attached storage first, however it will not retroactively move any filtered items from anywhere else in the network to its attached storage."
			]
			old: [
				"The &bME Storage Bus&f, when facing some external storage container, will allow the container to be used as though it were part of the ME network, allowing items to be taken out from the container or inserted into it purely via ME."
				""
				"Storage buses can be filtered and given specific priorities such that specific items will try to go to the attached storage first, however it will not retroactively move any filtered items from anywhere else in the network to its attached storage."
			]
		}
		quest.6F3D0A248B5A9CA2.quest_desc: {
			new: [
				"&bSpatial Storage Cells&f are used to hold one defined volume each, and come in three different capacities allowing for a maximum of 2x2x2, 16x16x16 and 128x128x128 blocks' worth of space. "
				""
				"Upon encoding, a cell is allocated a section of space within the spatial storage &edimension&f, along with a unique ID corresponding to the region allocated to the cell. An encoded cell can still be used within the Spatial IO Port to retrieve any stored blocks and entities. "
				""
				"From then on, any blocks contained either within the cell's region of space or in an SCS with the same size as the one used for the initial encoding can be moved back into the overworld or into the spatial dimension respectively. If there are blocks both within the spatial region and within the SCS, these will simply swap places accordingly."
			]
			old: [
				"&bSpatial Storage Cells&f are used to hold one defined volume each, and come in three different capacities allowing for a maximum of 2x2x2, 16x16x16 and 128x128x128 blocks' worth of space."
				""
				"Upon encoding, a cell is allocated a section of space within the spatial storage &edimension&f, along with a unique ID corresponding to the region allocated to the cell. An encoded cell can still be used within the Spatial IO Port to retrieve any stored blocks and entities."
				""
				"From then on, any blocks contained either within the cell's region of space or in an SCS with the same size as the one used for the initial encoding can be moved back into the overworld or into the spatial dimension respectively. If there are blocks both within the spatial region and within the SCS, these will simply swap places accordingly."
			]
		}
		quest.18DFB25DC48D8BF7.quest_desc: {
			new: [
				"The Spatial Containment Structure (SCS) consists of a cage of &bSpatial Pylons&f covering the volume you wish to enclose in a Spatial IO cell. At the absolute minimum, an SCS requires three lines of spatial pylon blocks, one for each dimension of the space being contained (length, width, height). "
				""
				"However, Spatial IO is an extremely power-hungry feature, especially when trying to capture much larger spaces (up to 128x128x128). Having more spatial pylons included in the SCS around the desired volume will increase its overall &eefficiency&f, allowing it to use less energy to capture. "
				""
				"Also, be mindful that each individual pylon (regardless of its length) takes up one channel. For particularly large spaces, you may wish to build a dedicated network with a controller to fit all the required pylons."
			]
			old: [
				"The Spatial Containment Structure (SCS) consists of a cage of &bSpatial Pylons&f covering the volume you wish to enclose in a Spatial IO cell. At the absolute minimum, an SCS requires three lines of spatial pylon blocks, one for each dimension of the space being contained (length, width, height)."
				""
				"However, Spatial IO is an extremely power-hungry feature, especially when trying to capture much larger spaces (up to 128x128x128). Having more spatial pylons included in the SCS around the desired volume will increase its overall &eefficiency&f, allowing it to use less energy to capture."
				""
				"Also, be mindful that each individual pylon (regardless of its length) takes up one channel. For particularly large spaces, you may wish to build a dedicated network with a controller to fit all the required pylons."
			]
		}
		task.23D186249A999B8C.title: {
			new: "Quartz Cutting Knives"
			old: "Quartz Cutting Knife"
		}
		task.38E290AC5E011888.title: {
			new: "ME Dense Smart Cables"
			old: "Dense Smart Cable"
		}
		quest.1B686954D34A0F23.quest_desc: {
			new: ["The &bQuartz Wrench&f does what any regular tech mod wrench would do. It rotates blocks and devices along the face you right-click on and dismantles them when right-clicked while sneaking.\\n\\nThis Wrench comes in both Certus Quartz and Nether Quartz varieties."]
			old: [
				"La &bQuartz Wrench&f hace lo que cualquier llave de modificación tecnológica haría. Gira bloques y dispositivos a lo largo de la cara en la que haces clic derecho y los desmonta cuando haces clic derecho mientras te mueves sigilosamente."
				""
				"La llave de AE2 viene en versiones de cuarzo certus y de cuarzo del Nether."
			]
		}
		quest.4597D3B3BDC2BED5.quest_desc: {
			new: ["The &bMolecular Assembler&f is AE2's equivalent of an automatic crafting table, required to fulfil any and all &ecrafting&f pattern jobs.\\n\\nMolecular Assemblers are capable of transferring power and channels to other ME devices connected to it, but will not themselves take up a channel. Up to 6 MAs can be connected to a single Pattern Provider (if employed) to allow for more crafts to be done in parallel.\\n\\nMAs also each have their own dedicated slot for a single crafting pattern, allowing them to function standalone when powered. When operated in this way, any matching items inserted into the MA will be automatically crafted into the result of the pattern."]
			old: [
				"El &bensamblador molecular&f es el equivalente de AE2 a una mesa de fabricación automática, necesaria para realizar todas y cada una de las tareas de &efabricación&f de patrones."
				""
				"Los ensambladores moleculares pueden transferir energía y canales a otros dispositivos ME conectados a ellos, pero no ocupan un canal. Se pueden conectar hasta 6 MA a un único proveedor de patrones (si se utiliza) para permitir que se realicen más fabricaciones en paralelo."
				""
				"Los MA también tienen su propia ranura dedicada para un único patrón de fabricación, lo que les permite funcionar de forma independiente cuando están encendidos. Cuando se operan de esta manera, cualquier elemento coincidente insertado en el MA se fabricará automáticamente en el resultado del patrón."
			]
		}
		quest.69B7DE2283B4EE6C.quest_desc: {
			new: ["The &bCrafting Co-Processing Unit&f helps speed up crafting jobs by allowing pattern providers to either send items out to their connected devices faster or to work concurrently to make multiple required ingredients.\\n\\nThe base AE2 co-processor provides one co-processor 'thread' to assist this, while the co-processing unit from &dMEGA Cells&f provides 4 threads in a single such block."]
			old: [
				"La &bUnidad de coprocesamiento de elaboración&f ayuda a acelerar los trabajos de elaboración al permitir que los proveedores de patrones envíen elementos a sus dispositivos conectados más rápido o trabajen simultáneamente para fabricar los múltiples ingredientes necesarios."
				""
				"El coprocesador AE2 básico proporciona un \"hilo\" de coprocesador para ayudar con esto, mientras que la unidad de coprocesamiento de &dMEGA Cells&f proporciona 4 hilos en un solo bloque de este tipo."
			]
		}
		quest.2C04B3BA507D5673.quest_desc: {
			new: ["&bPatterns&f are what hold an encoded recipe to be fulfilled by a Pattern Provider. To encode a recipe onto a Pattern, the &bME Pattern Encoding Terminal&f must be used.\\n\\nPatterns can be set to hold either a regular &ecrafting&f recipe, which will require the use of a &eMolecular Assembler&f on the face of its Provider, or a more general '&eprocessing&f' recipe, wherein any input items can be sent out by the provider into some other machine block or specialised processing plant."]
			old: [
				"Los &bPatrones&f son los que contienen una receta codificada que debe ser cumplida por un Proveedor de Patrones. Para codificar una receta en un Patrón, se debe utilizar la &bTerminal de Codificación de Patrones ME&f."
				""
				"Los patrones se pueden configurar para que contengan una receta de &ecrafting&f regular, que requerirá el uso de un &eEnsamblador Molecular&f en la cara de su Proveedor, o una receta de \"&eprocesamiento&f\" más general, en la que el proveedor puede enviar cualquier elemento de entrada a algún otro bloque de máquina o planta de procesamiento especializada."
			]
		}
		quest.01F3F0C25BA72BDA.quest_desc: {
			new: [
				"Aside from the storage of items and fluids, AE2 also provides a native way of storing entire &estructures&f inside of storage cells, not too dissimilarly to the Compact Machines mod. "
				""
				"The &bSpatial IO Port&f allows structures contained within a &bSpatial Containment Structure&f to be captured within a specially-designed storage cell, activated via a redstone signal. "
				""
				"If a mob or player happens to stand inside of the SCS while the space is being captured, they too will be transported to where the rest of the space goes, i.e. in a dedicated dimension. Just make sure you have a way to get back out and in if you're the one being captured."
			]
			old: [
				"Aside from the storage of items and fluids, AE2 also provides a native way of storing entire &estructures&f inside of storage cells, not too dissimilarly to the Compact Machines mod."
				""
				"The &bSpatial IO Port&f allows structures contained within a &bSpatial Containment Structure&f to be captured within a specially-designed storage cell, activated via a redstone signal."
				""
				"If a mob or player happens to stand inside of the SCS while the space is being captured, they too will be transported to where the rest of the space goes, i.e. in a dedicated dimension. Just make sure you have a way to get back out and in if you're the one being captured."
			]
		}
		quest.6431A384DDFBF439.quest_desc: {
			new: [
				"The &bNetwork Tool&f is an important tool throughout AE2, which is used to display various details of a network on-screen such as overall power consumption and storage. "
				""
				"As an added bonus, it also provides its own small inventory used to hold &eupgrade cards&f, which can be accessed when looking at any upgradeable device's screen for easy replacement. However, it cannot rotate blocks attached to the ME network like a regular wrench, only dismantle them when sneaking."
			]
			old: [
				"La herramienta de red es una herramienta importante en AE2, que se utiliza para mostrar varios detalles de una red en pantalla, como el consumo de energía general y el almacenamiento."
				""
				"Como beneficio adicional, también proporciona su propio inventario pequeño que se utiliza para guardar tarjetas de actualización, a las que se puede acceder al mirar la pantalla de cualquier dispositivo actualizable para reemplazarlas fácilmente. Sin embargo, no puede girar los bloques conectados a la red ME como una llave inglesa normal, solo los desmonta cuando se escabulle."
			]
		}
		quest.5C22E3103544B120.title: {
			new: "Basic Cabling"
			old: "Cableado básico"
		}
		task.64EAD3DE84E94F02.title: {
			new: "ME Covered Cables"
			old: "Covered Cable"
		}
		quest.30E853CE699E669B.quest_desc: {
			new: ["Before you can carry out an auto-crafting job, you need a device to actually store the request itself along with any interim items for multi-step crafts. This device is known as a &ecrafting CPU&f.\\n\\nA crafting CPU is a multiblock structure requiring at least one &bCrafting Storage&f block, optionally along with any other Crafting Unit. The multiblock can be made in any size, but must be a solid cuboid in order to form and function accordingly."]
			old: [
				"Antes de poder llevar a cabo un trabajo de creación automática, necesitas un dispositivo para almacenar la solicitud junto con los elementos intermedios para las creaciones de varios pasos. Este dispositivo se conoce como &eCPU de creación&f."
				""
				"Una CPU de creación es una estructura multibloque que requiere al menos un bloque de &bAlmacenamiento de creación&f, opcionalmente junto con cualquier otra Unidad de creación. El multibloque se puede hacer en cualquier tamaño, pero debe ser un cuboide sólido para formarse y funcionar adecuadamente."
			]
		}
		quest.00611844AFD5C31E.quest_desc: {
			new: ["While the Inscriber and Charger will natively accept RF/FE, the vast majority of an ME network uses its own dedicated power system called AE.\\n\\nRF/FE can be converted into the native AE at a ratio of 2:1 RF:AE, either directly through an ME Controller, or through the &bEnergy Acceptor&f, which can instead be connected to any part of the network."]
			old: [
				"Si bien la Prensa y el Cargador aceptan RF/FE de forma nativa, la gran mayoría de una red ME utiliza su propio sistema de energía dedicado llamado AE."
				""
				"La RF/FE se puede convertir en la AE nativa en una proporción de 2:1 RF:AE, ya sea directamente a través de un Controlador ME o a través del &bAceptor de Energía&f, que puede conectarse a cualquier parte de la red."
			]
		}
		quest.4E8A05C3BFA80540.quest_desc: {
			new: ["Arguably the most important aspect of Applied Energistics 2 is its storage system, making use of digital &eStorage Cells&f. These cells are accessible through either an &eME Chest&r for single cells, or an &eME Drive&r for multiple cells.\\n\\nThe &bME Chest&f holds a single Cell at a time, which can then be read from and written to from any other terminal on the same network. The ME Chest itself also provides its own terminal screen on the top with specific access only to the cell it contains.\\n\\nThe &bME Drive&f can hold up to 10 assorted Storage Cells in the space of a single block and a single ME channel. However, it does not provide its own terminal screen, requiring some external terminal elsewhere on the network for storage access."]
			old: [
				"Se podría decir que el aspecto más importante de Applied Energistics 2 es su sistema de almacenamiento, que hace uso de &eStorage Cells&f digitales. Estas celdas son accesibles a través de un &eME Cofre&r para celdas individuales, o un &eME Rack Disco&r para celdas múltiples."
				""
				"El &bME Cofre&f contiene una sola celda a la vez, que luego se puede leer y escribir desde cualquier otro terminal en la misma red. El ME Chest en sí también proporciona su propia pantalla de terminal en la parte superior con acceso específico solo a la celda que contiene."
				""
				"El &bME Rack Disco&f puede contener hasta 10 celdas de almacenamiento variadas en el espacio de un solo bloque y un solo canal ME. Sin embargo, no proporciona su propia pantalla de terminal, lo que requiere algún terminal externo en otro lugar de la red para acceder al almacenamiento."
			]
		}
		quest.68B0B3DAF1145191.title: {
			new: "First Things First"
			old: "Lo primero es lo primero"
		}
		quest.6144202A97C6CD1C.quest_desc: {
			new: ["The &bQuartz Cutting Knife&f, like the wrench, comes in both nether and certus quartz flavours and is a useful crafting tool to have on hand.\\n\\nCables can also be separated without needing to be coloured by attaching a &bCable Anchor&f between them, crafted using this knife and craftable up to 50 times with the same knife before it breaks.\\n\\nCable Anchors can also be used to craft &bCable Facades&f, allowing you to disguise cables within walls by covering them with the face of an arbitrary block. While facade recipes are hidden in JEI, you can still craft them by taking any regular block and surrounding it with 4 cable anchors in the crafting grid.\\n\\nAside from crafting anchors, the cutting knife also has another use: right-clicking with the knife will open a small GUI that allows you to craft &bInscriber Name Presses&f. When given a name, these presses can be used inside of an Inscriber to rename any input item with the name of the press. Two of these presses can be concatenated in the inscriber to rename the item to the name of the top press, followed by the bottom one."]
			old: [
				"El &bcuchillo de corte de cuarzo&f, al igual que la llave, viene en versiones de cuarzo del Nether y del Certus y es una herramienta de fabricación útil para tener a mano."
				""
				"Los cables también se pueden separar sin necesidad de colorearlos colocando un &banclaje de cable&f entre ellos, fabricado con este cuchillo y fabricable hasta 50 veces con el mismo cuchillo antes de que se rompa."
				""
				"Los anclajes de cable también se pueden usar para fabricar &bfachadas de cable&f, lo que te permite disfrazar cables dentro de las paredes cubriéndolos con la cara de un bloque arbitrario. Si bien las recetas de fachadas están ocultas en JEI, aún puedes fabricarlas tomando cualquier bloque normal y rodeándolo con 4 anclajes de cable en la cuadrícula de fabricación."
				""
				"Además de fabricar anclajes, el cuchillo de corte también tiene otro uso: al hacer clic derecho con el cuchillo se abrirá una pequeña interfaz gráfica de usuario que te permite fabricar &bprensas de nombre de inscriptor&f. Cuando se les da un nombre, estas prensas se pueden usar dentro de un inscriptor para cambiar el nombre de cualquier elemento de entrada con el nombre de la prensa. Se pueden concatenar dos de estas prensas en el inscriptor para renombrar el elemento con el nombre de la prensa superior, seguido por el de la inferior."
			]
		}
		quest.6D54B45CDA70FEAB.quest_desc: {
			new: ["The &bEnergy Card&f can be applied to most chargeable devices like Portable Cells and Wireless Terminals (covered later) to also increase &otheir&r energy buffer."]
			old: ["La Energy Card se puede aplicar a la mayoría de los dispositivos cargables, como celdas portátiles y terminales inalámbricas (que se tratan más adelante), para aumentar también su reserva de energía."]
		}
		task.7FC3DAA1BD5016A0.title: {
			new: "ME Smart Cables"
			old: "Smart Cable"
		}
		quest.4BF0BB763BFFACF0.quest_desc: {
			new: [
				"Arguably the most important resource you will need next is &eFluix&f, used throughout the vast majority of AE2 devices and serving as a base for crafting all of the cabling within an ME network. "
				""
				"You'll typically want to mass produce these, and the way to do so is to make a &bFluix Crystal&f by throwing &eNether Quartz&f, &e&oCharged&r&e Certus quartz&r and &eRedstone&f together in a pool of water. This will give you a &eFluix Crystal&r which you can turn to dust in an Inscriber."
			]
			old: [
				"Podría decirse que el recurso más importante que necesitarás a continuación es &eFluix&f, que se utiliza en la gran mayoría de dispositivos AE2 y que sirve como base para fabricar todo el cableado dentro de una red ME."
				""
				"Normalmente querrás producirlos en masa, y la forma de hacerlo es hacer un &bCristal de Fluix&f arrojando &eCuarzo del Nether&f, &e&oCuarzo Certus cargado&r&e y &eRedstone&f juntos en un charco de agua. Esto te dará un &eCristal de Fluix&r que puedes convertir en polvo en una prensa."
			]
		}
		quest.2F16B6A173525277.quest_desc: {
			new: [
				"The last piece of the puzzle for any large ME network is the &bME Controller&f. "
				""
				"A controller supplies an ME Network with a far larger number of channels than the standard 8 channels for ad-hoc networks, providing 32 channels out of each face of the block for a total of 216 channels. "
				""
				"That's only for a single-block controller, however, since the ME Controller is in fact a multi-block structure. The controller can be up to 7x7x7 blocks in size and can come in any freeform arrangement within that maximum size. Each individual block can then provide its own separate set of channels, so long as no single controller block is surrounded by 4 other blocks along the same plane. "
				""
				"An ME Network may only contain one multiblock controller at any given time. Attempting to connect more than one controller on separate parts of the network will cause a conflict, shutting down the whole network."
			]
			old: [
				"La última pieza del rompecabezas para cualquier red ME grande es el &bControlador ME&f."
				""
				"Un controlador proporciona a una red ME una cantidad de canales mucho mayor que los 8 canales estándar para redes ad-hoc, proporcionando 32 canales de cada cara del bloque para un total de 216 canales."
				""
				"Sin embargo, esto es solo para un controlador de un solo bloque, ya que el controlador ME es de hecho una estructura de múltiples bloques. El controlador puede tener un tamaño de hasta 7x7x7 bloques y puede venir en cualquier disposición de forma libre dentro de ese tamaño máximo. Cada bloque individual puede proporcionar su propio conjunto de canales, siempre que ningún bloque de controlador esté rodeado por otros 4 bloques a lo largo del mismo plano."
				""
				"Una red ME solo puede contener un controlador multibloque en un momento dado. Intentar conectar más de un controlador en partes separadas de la red provocará un conflicto, apagando toda la red."
			]
		}
		quest.5233A447BAA4593C.title: {
			new: "Advanced Cabling"
			old: "Cableado avanzado"
		}
	}
	"chapters/powah.snbt": {
		quest.4F1FFC02F4EAA2E6.title: {
			new: "Tier: &4Nitro"
			old: "Tier: &4Nitro&r"
		}
		quest.6B2027DA7AA6FF34.title: {
			new: "&aWelcome to &9Powah&r!!!"
			old: "&aWelcome to&r &9Powah&r!!!"
		}
		quest.3CB6DC5B09C62CFE.quest_desc: {
			new: ["&5Ender Gates&r are used to transfer power wirelessly to and from an adjacent block into the &7Ender Network&r.\\n\\nThink of these like wireless access points to your wireless network of power.\\n\\nNote: You can only add &apower storage capacity&r using an Ender Cell."]
			old: [
				"&5Ender Gates&r are used to transfer power wirelessly to and from an adjacent block into the &7Ender Network&r."
				""
				"Think of these like wireless access points to your wireless network of power."
				""
				"Note: You can only add &apower storage capacity&r using an Ender Cell."
			]
		}
		quest.1B0087400B0B8B49.quest_desc: {
			new: ["The &9Reactor&r is a 3x4x3 multiblock generator that burns &aUrananite&r as fuel to produce FE.\\n\\nTo build it, you'll need to make a total of 36 Reactor Blocks. While holding 36 in hand, placing one block will auto-build the reactor. Make sure to clear out some room first!\\n\\nYou'll want to cool the reactor down for it to create more FE, and you can do this with either solid or liquid &bcoolant&r. To use a solid coolant, you'll also need to give it some liquid coolant as well. &bDry Ice&r makes for a great solid coolant! (Note: 1 Water Bucket will do).\\n\\nYou can also increase the FE generation by keeping the fuel buffer full, as well as adding both Coal and Redstone to the Reactor. Using Blocks of either will also work!"]
			old: [
				"The &9Reactor&r is a 3x4x3 multiblock generator that burns &aUrananite&r as fuel to produce FE."
				""
				"To build it, you'll need to make a total of 36 Reactor Blocks. While holding 36 in hand, placing one block will auto-build the reactor. Make sure to clear out some room first!"
				""
				"You'll want to cool the reactor down for it to create more FE, and you can do this with either solid or liquid &bcoolant&r. To use a solid coolant, you'll also need to give it some liquid coolant as well. &bDry Ice&r makes for a great solid coolant! (Note: 1 Water Bucket will do)"
				""
				"You can also increase the FE generation by keeping the fuel buffer full, as well as adding both Coal and Redstone to the Reactor. Using Blocks of either will also work!"
			]
		}
		quest.7D7983F39E6E818D.title: {
			new: "Tier: &9Niotic"
			old: "Tier: &9Niotic&r"
		}
		quest.3DDF87A1E5F5D009.title: {
			new: "The &9Energizing Orb"
			old: "The &9Energizing Orb&r"
		}
		quest.5E090C9BB4DAA5D4.title: {
			new: "Tier: &aEnergized"
			old: "Tier: &aEnergized&r"
		}
		quest.25EFC21A3C48E0B6.title: {
			new: "Tier: &2Spirited"
			old: "Tier: &2Spirited&r"
		}
		quest.6D88C19F47D0D469.title: {
			new: "Tier: &7Tiny"
			old: "Tier: &7Tiny&r"
		}
		quest.562BD37539EE318E.title: {
			new: "Tier: &cBlazing"
			old: "Tier: &cBlazing&r"
		}
		quest.66ECC26BC81D0093.title: {
			new: "Tier: &bBasic"
			old: "Tier: &bBasic&r"
		}
		quest.78202A1CF5D86B94.quest_desc: {
			new: ["The &9Power Bank&r of Powah.\\n\\nThese can also be used to upgrade the total power storage capacity of your wireless &7Ender Networks&r."]
			old: [
				"The &9Power Bank&r of Powah."
				""
				"These can also be used to upgrade the total power storage capacity of your wireless &7Ender Networks&r."
			]
		}
		quest.6B2027DA7AA6FF34.quest_desc: {
			new: ["&9Powah&r is a tech mod that's all about generating, storing, and transmitting &dPower&r. Ranging from basic FE generation to &aReactors&r that produce &b250k FE/t&r, Powah has you covered!\\n\\nTo get started, get some &aUraninite&r!"]
			old: [
				"&9Powah&r is a tech mod that's all about generating, storing, and transmitting &dPower&r. Ranging from basic FE generation to &aReactors&r that produce &b250k FE/t&r, Powah has you covered!"
				""
				"To get started, go out and mine some &aUraninite&r!"
			]
		}
		quest.3DDF87A1E5F5D009.quest_desc: {
			new: [
				"In the beginning, you can get by with creating the &7Starter&r and &bBasic&r tier machines using Iron, but you'll eventually need to create energized mats using the &9Energizing Orb&r.\\n\\nThe &9Energizing Orb&r will energize items using nearby &aEnergizing Rods&r within a 9x9 area around it, creating better materials for you to use to progress through the &eTiers&r in Powah.\\n\\nTo power the orb, you'll need to attach Energizing Rods to Energy Cables that are being supplied with energy. If you want the Orb to energize faster, either make more rods, upgrade to higher tier rods, or both! To see if the Rods are connected, set your &aWrench&r to link mode and you can link any Rod to the Orb."
				""
				"{image:atm:textures/questpics/powah/powah_energizing.png width:200 height:200 align:1}"
			]
			old: [
				"In the beginning, you can get by with creating the &7Starter&r and &bBasic&r tier machines using Iron, but you'll eventually need to create energized mats using the &9Energizing Orb&r."
				""
				"The &9Energizing Orb&r will energize items using nearby &aEnergizing Rods&r within a 9x9 area around it, creating better materials for you to use to progress through the &eTiers&r in Powah."
				""
				"To power the orb, you'll need to attach Energizing Rods to energy cables that are being supplied with energy. If you want the Orb to energize faster, either make more rods, upgrade to higher tier rods, or both! To see if the Rods are connected, set your &aWrench&r to link mode and you can link any Rod to the Orb."
				""
				"{image:atm:textures/questpics/powah/powah_energizing.png width:200 height:200 align:1}"
			]
		}
		quest.7E92ED270C67FDE5.quest_desc: {
			new: ["Almost every single machine you can make in the mod will require a &9Dielectric Casing&r.\\n\\nYou'll need to make the &bPaste&r first, as well as some &aRods&r to progress!"]
			old: [
				"Almost every single machine you can make in the mod will require a &9Dielectric Casing&r."
				""
				"You'll need to make the &bPaste&r first, as well as some &aRods&r to progress!"
			]
		}
		quest.52E59FCB39D66BCF.quest_desc: {
			new: ["One of the best options for \"Passive Power\", the &9Thermal Generator&r will produce FE when placed over a &cHeat Source&r and given a steady supply of water.\\n\\nThere are currently 3 blocks you can place this over: a Magma block which produces the lowest, a lava source block which is a little better, or a &cBlock of Blazing Crystal&r, which provides the most heat. "]
			old: [
				"One of the best options for \"Passive Power\", the &9Thermal Generator&r will produce FE when placed over a &cHeat Source&r and given a steady supply of water."
				""
				"There are currently 3 blocks you can place this over: a Magma block which produces the lowest, a lava source block which is a little better, or a &cBlock of Blazing Crystal&r, which provides the most heat. "
			]
		}
	}
	"chapters/storage.snbt": {
		quest.1A4B1CA7EC15348E.quest_desc: {
			new: ["Using a &aLinking Tool&r, you can link 2 Ender Drawers to sync up their contents.\\n\\nThis works just like an Ender Chest, but as a Drawer.\\n\\nTo link, right-click the first Ender Drawer with the &aLinking Tool&r, then left-click the second Ender Drawer."]
			old: [
				"Using a &aLinking Tool&r, you can link 2 Ender Drawers to sync up the contents."
				""
				"This works just like an Ender Chest, but for Drawers."
				""
				"To link, Right click the first Ender Drawer with the &aLinking Tool&r, then left click the second Ender Drawer to sync."
			]
		}
		quest.1A4B1CA7EC15348E.quest_subtitle: {
			new: "Dimensional Drawer..."
			old: "Dimensional Drawer.... if you will."
		}
		quest.6A2B2C5E2ADCE366.quest_desc: {
			new: ["Sophisticated Backpacks offers upgradable Backpacks that can use filters to add nifty features!\\n\\nBackpacks can be put in your Curios Back slot and they can be dyed."]
			old: ["¡Las mochilas sofisticadas ofrecen mochilas actualizables que también pueden usar filtros para agregar funciones ingeniosas!"]
		}
		quest.1FE052F643401232.quest_subtitle: {
			new: "The Base for Upgrades"
			old: "La base para los filtros de mochila"
		}
		quest.6FBAE89EE782DABA.quest_subtitle: {
			new: "The Brain of the Drawers"
			old: "The Brain of the Drawers."
		}
		quest.0682DC1F2417DAEB.quest_desc: {
			new: ["Functional Storage is a storage mod that adds varuious useful items to help with storage and ways of storing stacks of the same items.\\n\\nThis can be useful for items like Cobblestone, Dirt and more."]
			old: [
				"Functional Storage es un mod para almacenar pilas de los mismos elementos."
				""
				"Esto es útil para elementos como Cobblestone, tierra, etc."
			]
		}
		quest.7C07D6A33F7ADB02.quest_desc: {
			new: [
				"This is a Backpack upgrade so you can put your Backpack in your Backpack."
				""
				"So you can have your Backpack in your Backpack for when you need your Backpack in your Backpack."
			]
			old: [
				"So we got a backpack upgrade to put your backpack in your backpack."
				""
				"So you can have your backpack in your backpack when you need your backpack in your backpack."
			]
		}
		quest.072FBEB0F6F1BC48.quest_desc: {
			new: ["Used to link Drawers to a Controller and to link up Ender Drawers.\\n\\nTo link Drawers to the Controller, right click the Controller block to start configuration. Right clicking Drawers will add them to the network.\\n\\nHolding the tool will show you what Drawers are connected to the Controller."]
			old: [
				"Se utiliza para vincular los drawers a un storage controller y tambien para los Ender Drawers."
				""
				"Para vincular un drawer al controlador, haga clic derecho en el bloque \"Storage Controller\" para iniciar la configuración. Al hacer clic derecho en los drawers, se agregarán a la red."
				""
				"Si mantiene presionada la herramienta, verá qué drawers están conectados al controlador."
			]
		}
		quest.5A94A2664BFDD7B9.quest_desc: {
			new: ["Welcome to the Basic Storage Chapter!\\n\\nYou'll find all of the basic ways to store items without needing power, as well as useful items for your storage needs!"]
			old: [
				"¡Bienvenido al capítulo de almacenamiento básico!"
				""
				"¡Encontrará todas las formas básicas de almacenar artículos sin energía, así como artículos útiles para sus necesidades de almacenamiento!"
			]
		}
		quest.508A8366219175FE.quest_desc: {
			new: ["The Configuration Tool is used to lock Drawers for them to remember the item it has inside.\\n\\nThis can be useful whenever you set up a system to push and pull from Drawers. The locked Drawer will not replace the item that was locked on it!"]
			old: [
				"The Configuration Tool is used to lock drawers for them to remember the item it has inside."
				""
				"This is useful whenever you set up a system to pull and push from drawers. The locked drawer will not replace the item that was locked on it!"
			]
		}
		quest.2B422B7E0CE3590D.quest_subtitle: {
			new: "Auto Compacts/Decompacts"
			old: "Auto-Convert to blocks."
		}
		quest.5A94A2664BFDD7B9.title: {
			new: "Basic Storage"
			old: "Almacenamiento básico"
		}
		quest.4B62AF0405F68041.quest_subtitle: {
			new: "All Stocked up"
			old: "Stocking Up"
		}
		quest.5E4BC0F59C90433A.quest_desc: {
			new: ["Sophisticated Storage allows you to upgrade your Chests and Barrels with metals to increase their storage! You can also add upgrades to increase their functionality.\\n\\nThese chests are just like a vanilla Chest or Barrel, but they have a slot for a Storage Upgrade!"]
			old: ["¡Igual que un cofre de vanilla, pero tiene una ranura para una mejora de almacenamiento!"]
		}
		quest.5E4FE420B6D2C97F.quest_subtitle: {
			new: "More Filtering Options"
			old: "Compacts items in the backpack to their 3x3 recipe. "
		}
		quest.0E0CAA31480EC0A1.quest_subtitle: {
			new: "Allows the backpack to pick up items."
			old: "Allows the backpack to pickup items."
		}
		quest.7C07D6A33F7ADB02.quest_subtitle: {
			new: "Backpacks in your Backpacks?"
			old: "I heard you like backpacks in your backpacks."
		}
		quest.0682DC1F2417DAEB.quest_subtitle: {
			new: "Storage Drawers Distant Relative"
			old: "Almacenamiento"
		}
		quest.3A1D07AED2A841E4.quest_subtitle: {
			new: "Automatic"
			old: "Auto-smelt items in the backpack."
		}
		quest.7EF57BBEAA4B6B08.quest_desc: {
			new: ["Looking to create virtual storage using a mod like &9Applied Energistics 2&r?\\n\\nThese are great ways to upgrade your storage, but it is important to talk about &eNBT Items&r and the best way to store them.\\n\\nNBT items are items with extra tags attached to them. Enchanted items, items with durability and more. These are items with NBT tags attached to them. Because of this, they don't usually stack.\\n\\nWhen you store a lot of these into a storage system like AE2, you run the chance of creating issues for your save or server.\\n\\nBecause of this, it is best to store them in Chests or Bags!"]
			old: [
				"¿Quiere crear almacenamiento virtual utilizando &9Refined Storage&r o &9Applied Energistics 2&r?"
				""
				"Ambas son excelentes formas de actualizar su almacenamiento, pero es importante hablar sobre los &eNBT Items&r y la mejor manera de almacenarlos."
				""
				"Los artículos NBT son artículos con etiquetas adicionales adjuntas. Objetos encantados, objetos con durabilidad, gemas de apoteosis... todos estos son objetos con etiquetas NBT adheridas. Debido a esto, no suelen"
				""
				"Cuando almacena muchos de estos en un sistema de almacenamiento como RS o AE2, corre el riesgo de crear problemas para su guardado o servidor."
				""
				"¡Por eso es mejor guardarlos en cofres o bolsas!"
			]
		}
		quest.1985CFD1F0425E88.title: {
			new: "&eAdvanced Pickup Upgrade"
			old: "Mejora De Agarre"
		}
		quest.5E4BC0F59C90433A.title: {
			new: "Sophisticated Storage"
			old: "\"Vanilla\" Chest"
		}
		quest.6A2B2C5E2ADCE366.quest_subtitle: {
			new: "Inventories are too Small"
			old: "Mochilas sofisticadas"
		}
		quest.2746575C929B6C50.quest_desc: {
			new: ["Drawers can be 1x1, 2x1 or 2x2. Drawers can hold a ton of stacks of 1/2/4 items depending on the type of Drawer."]
			old: ["Crea un cajón de 1x1. Este artículo admite un montón de stacks de 1 artículo."]
		}
		quest.5E4BC0F59C90433A.quest_subtitle: {
			new: "\"Vanilla Chest\""
			old: "El cofre inicial."
		}
		quest.2B422B7E0CE3590D.quest_desc: {
			new: ["The Compacting Drawer can convert items placed inside to their nugget or block forms.\\n\\nFor example: An Iron Ingot placed in this will allow you to pull out 9 nuggets, or if more Iron is placed in, will covert it to Iron Blocks."]
			old: [
				"This item can convert items placed inside to their nugget or block forms."
				""
				"For example: An Iron Ingot placed in this will allow you to pull out 9 nuggets, or if more iron is placed in, will covert it to Iron Blocks."
			]
		}
		quest.4B62AF0405F68041.quest_desc: {
			new: ["Adds a filter that allows you to tell the Backpack which items it should keep stocked. Shift right-clicking an inventory will refill it."]
			old: ["Adds a filter that allows you to tell the backpack which items it should keep stocked. Shift-Right Clicking an inventory will refill it."]
		}
		quest.1FE052F643401232.quest_desc: {
			new: ["You will need these to make Backpack Upgrades."]
			old: ["Los necesitarás para realizar mejoras en el filtro de la mochila."]
		}
		quest.6FBAE89EE782DABA.quest_desc: {
			new: ["When placed and connected with the &aLinking Tool&r to other Drawers, the Controller acts as a \"Hub\".\\n\\nIf you double right-click this, all the items in your inventory that have a slot in the Drawer network will be pulled.\\n\\nBy sneak right-Clicking the controller with an empty hand, you can open the upgrades tab, add normal storage upgrades to those slots to increase the Controller's range. Max range is 40 blocks for all sides, or a cube of 80x80x80."]
			old: [
				"When placed and connected with the &aLinking Tool&r to other drawers, this block acts as a \"Hub.\""
				""
				"If you double right-click this, all items within the Storage Drawers \"Network\" will be pulled from your inventory."
			]
		}
		quest.77F241BEE9902751.quest_desc: {
			new: ["The biggest of the chests from Sophisticated Storage"]
			old: [""]
		}
		quest.58514FDE153FD971.quest_subtitle: {
			new: "Iron Chests?"
			old: "Un solo cofre del tamaño de 2."
		}
		quest.2746575C929B6C50.quest_subtitle: {
			new: "Stacks on Stacks"
			old: "Stacks y Stacks"
		}
	}
	file.snbt: {
		file.0000000000000001.title: {
			new: "&f&lAll The Mods 10: To the Sky!&r"
			old: "&f&lArcane Ascension!&r"
		}
	}
	"chapters/hostile_neural_networks.snbt": {
		quest.104EBBC08B4733F5.quest_desc: {
			new: ["The &dSimulation Chamber&r is the main machine within HNN.\\n\\nWhen given power, it will run simulations based on the &bData Model&r that is placed inside. The power required also depends on the Data Model placed inside, and can be seen within the Model's tooltip. \\n\\nThe machine also requires at least one &9Prediction Matrix&r to run a simulation.\\n\\nThe result of the simulation will be output onto the Matrix. Simulations will always produce some kind of &eGeneralized Prediction&r, which can be used in various crafting recipes. They also vary depending on the origin of the mob in the Data Model.\\n\\nIf the simulation succeeds, you will receive a &dMob Prediction&r based off of the model. The higher the tier of the Data Model used, the higher the success rate is for a simulation."]
			old: [
				"The &dSimulation Chamber&r is the main machine within HNN."
				""
				"When given power, it will run simulations based on the &bData Model&r that is placed inside. The power required also depends on the Data Model placed inside, and can be seen within the Model's tooltip. "
				""
				"The machine also requires at least one &9Prediction Matrix&r to run a simulation."
				""
				"The result of the simulation will be output onto the Matrix. Simulations will always produce some kind of &eGeneralized Prediction&r, which can be used in various crafting recipes. They also vary depending on the origin of the mob in the Data Model."
				""
				"If the simulation succeeds, you will receive a &dMob Prediction&r based off of the model. The higher the tier of the Data Model used, the higher the success rate is for a simulation."
			]
		}
		quest.37EBB8E0D6E5F821.quest_desc: {
			new: [
				"&6Hostile Neural Networks&r (HNN for short) is a mod based around simulating mob kills for loot!\\n\\nTo do this, you will be collecting \"data\" on mobs, then running simulations from the data to create their drops!\\n"
				"{image:atm:textures/questpics/hnn.png width:150 height:150 align:center}"
			]
			old: [
				"&6Hostile Neural Networks&r (or HNN for short) is a mod based around simulating mob kills for loot!"
				""
				"To do this, you will be collecting \"data\" on mobs, then running simulations from the data to create their drops!"
			]
		}
		quest.3E3CBDCEAB0FF28F.quest_desc: {
			new: ["The &9Deep Learner&r is one of the core components of HNN.\\n\\nWith this item, you can right click to open up a HUD and store &6Data Models&r to gather data while killing mobs.\\n\\nEach Learner can hold 4 Data Models, and as long as you have the Learner anywhere in your inventory, it will collect data for the models placed inside!\\n\\nNote: You can have multiple Deep Learners in your inventory, and it will count the kills for all Data Models inside all of the Learners."]
			old: [
				"The &9Deep Learner&r is one of the core components of HNN."
				""
				"With this item, you can right click to open up a HUD and store &6Data Models&r to gather data while killing mobs."
				""
				"Each Learner can hold 4 Data Models, and as long as you have the Learner anywhere in your inventory, it will collect data for the models placed inside!"
				""
				"Note: You can have multiple Deep Learners in your inventory, and it will count the kills for all Data Models inside all of the Learners."
			]
		}
		quest.58C2ABED43B2EA61.quest_subtitle: {
			new: "\"Gathering Data\""
			old: "For \"Gathering Data\""
		}
		quest.3E3CBDCEAB0FF28F.title: {
			new: "&aLearning Mobs"
			old: "&aLearning Mobs&r"
		}
		quest.58C2ABED43B2EA61.title: {
			new: "&9Modeling Mobs"
			old: "&9Modeling Mobs&r"
		}
		quest.58C2ABED43B2EA61.quest_desc: {
			new: ["&9Model Frameworks&r are the starting point for creating Data Models.\\n\\nTo start collecting data on a specific mob, you'll want to make one of these then &9right click&r the mob you'd like to gather data on. When done properly, the Model Framework will turn into the Data Model of the mob you clicked on.\\n\\nTo gather data for that mob, place the newly created Data Model inside of a &aDeep Learner&r, then start killing that specific mob with the Deep Learner in your inventory."]
			old: [
				"&9Model Frameworks&r are the starting point for creating Data Models."
				""
				"To start collecting data on a specific mob, you'll want to make one of these then &9right click&r the mob you'd like to gather data on. When done properly, the Model Framework will turn into the Data Model of the mob you clicked on."
				""
				"To \"gather data\" for that mob, place the newly created Data Model inside of a &aDeep Learner&r, then start killing that specific mob with the Deep Learner in your inventory."
			]
		}
		quest.104EBBC08B4733F5.title: {
			new: "&aSimulating Deaths"
			old: "&aSimulating Deaths&r"
		}
		quest.14B3542ECB59869C.quest_desc: {
			new: ["The &5Loot Fabricator&r is the machine that gets you that sweet, sweet loot from Mob Predictions.\\n\\nWhen given power and a successful Mob Prediction, you will be able to choose which item you'd like to get from that mob's Data Model. The machine will remember your choice, so it can be automated.\\n\\nExamples of Mob Predictions:\\n\\n- &dEnder Dragons&r for &dDragon Eggs\\n - &2Zombies&r for Iron\\n - &0Withers&r for &5Nether Stars"]
			old: [
				"The &5Loot Fabricator&r is the machine that gets you that sweet, sweet loot from Mob Predictions."
				""
				"When given power and a successful Mob Prediction, you will be able to choose which item you'd like to get from that mob's Data Model. The machine will remember your choice, so it can be automated."
				""
				"Notable Mob Predictions:"
				""
				"- &dEnder Dragons&r for &dDragon Eggs&r"
				"- &2Zombies&r for Iron"
				"- &0Withers&r for &5Nether Stars&r"
			]
		}
		quest.14B3542ECB59869C.title: {
			new: "Creating &dLoot"
			old: "Creating &dLoot&r"
		}
		quest.34CD54347E9821B5.quest_desc: {
			new: ["Once you make your first Data Model, you'll need to level it up to be useful.\\n\\nData Models start out at the first tier: &7Faulty&r. You'll need to at least level it to &aBasic&r if you'd like to run some simulations on it!\\n\\nOnce placed inside of the Deep Learner, the HUD will tell you how many kills are required to level it up. You can also see this info in the tooltip of the Model itself."]
			old: [
				"Once you make your first Data Model, you'll need to level it up to be useful."
				""
				"Data Models start out at the first tier: &7Faulty&r. You'll need to at least level it to &aBasic&r if you'd like to run some simulations on it!"
				""
				"Once placed inside of the Deep Learner, the HUD will tell you how many kills are required to level it up. You can also see this info in the tooltip of the Model itself, although you'll have to do math."
			]
		}
	}
