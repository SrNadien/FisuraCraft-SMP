		quest.7F757CD6F8C57733.quest_desc: {
			new: ["The Energy Core is one, if not the, greatest Energy bank in all of Minecraft. And it all starts with the Core. This is the middle and heart of the Energy Core Multiblock (make sure it's a bit off the ground). When you place it down you can see it's GUI with the: Build Guide, Tier Down, Tier Up, and Assemble Core. The Tiers determine how big and powerful the Core is. The Build Guide shows you how to assemble this Tier of Core. If you have all the blocks necessary you can press Assemble Core and it will automatically make it!"]
			old: ["{atm9.quest.draconic.desc.core}"]
		}
		quest.60C27206F1414DD6.title: {
			new: "Projectile Immunity Cancellation Module"
			old: "{atm9.quest.draconic.PICaM}"
