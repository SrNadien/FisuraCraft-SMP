		quest.7143CE930D08F160.quest_desc: {
			new: ["Area of Effect is a phrase most Gamers would know. Basically it upgrades the working area of the Tool it's on. Pickaxes with 3x3 AOE will mine in a 3x3 area. Swords with 3x3 AOE will kill all mobs hit within that area. The better the upgrade the bigger the area. No, it's not stackable!"]
			old: ["{atm9.quest.draconic.desc.BAOEM}"]
