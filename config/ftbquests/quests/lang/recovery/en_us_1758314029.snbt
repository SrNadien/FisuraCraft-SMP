		quest.78FBB0C88182040E.title: {
			new: "Wyvern Projectile Penetration Module"
			old: "{atm9.quest.draconic.WPPeM}"
		}
		quest.61419D230687CBB5.quest_desc: {
			new: ["Velocity is the speed of an item at a certain direction. Since our Arrow aren't from Guardians of the Galaxy it basically just means the Speed of an Arrow. With each upgrade it takes less time from the Arrow to go from your Bow to your Target. Comes at a cost of a little inaccuracy."]
			old: ["{atm9.quest.draconic.desc.WPVeM}"]
		}
		quest.39865681B03CABAA.quest_desc: {
			new: ["Water is a little viscous, or atleast more dense than air. Because of that Mining Underwater is slower. You can use the Enchantment of Aqua Affinity, or use this Module. Your choice!"]
			old: ["{atm9.quest.draconic.desc.AAM}"]
		}
		quest.529123A789D790E3.title: {
