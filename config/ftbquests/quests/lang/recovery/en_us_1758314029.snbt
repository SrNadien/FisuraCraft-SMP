		}
		quest.4ABEF61DADBD0640.quest_desc: {
			new: ["Most Bows are Semi-Automatic. You have to draw the string, release, and put another Arrow in the bow, and repeat. Instead skip all that let the Bow automatically fire everytime it's fully drawn. Just hold Right Click and watch it go!"]
			old: ["{atm9.quest.draconic.desc.AFiM}"]
		}
		quest.6601ACCDDF6CA5FF.quest_desc: {
			new: ["The Reactor can only hold 1 Billion OP and while that may seem like a far number, it won't be for long. When Energy Saturation reaches 100%% it will increase Heat a ton which can lead to Meltdown. It will need 500,000,000 OP to activate and a Flux Gate will help limit how much OP comes in and out. (BTW 1 RF = 1 OP) They need Redstone to activate and can be used for both adding OP and taking out OP. You'll need Energy out to not Meltdown, try putting it in an Energy Core!"]
			old: ["{atm9.quest.draconic.desc.power}"]
		}
