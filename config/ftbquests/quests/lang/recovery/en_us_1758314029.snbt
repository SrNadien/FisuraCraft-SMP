		}
		quest.51CF09EC333DB1A3.quest_desc: {
			new: ["In order to Tier up in Draconic Evolution Fusion Crafting, the needed Injectors for a recipe must be atleast the Tier or higher. Like if you want to make the Wyvern Axe you need atleast 6 Wyvern Injectors, with 3 on each sides. Don't worry the Crafting Core stays the same!"]
