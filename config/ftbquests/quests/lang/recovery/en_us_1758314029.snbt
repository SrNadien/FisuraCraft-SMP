		quest.285656AF1F870AF8.quest_desc: {
			new: ["1 of the 2 Basic Tier Infusions but don't underestimate the Draconic Chest. It holds more space than a double chest, it can smelt and craft items, and best of all it can change colors! Easily my favorite Chest in any mod!"]
